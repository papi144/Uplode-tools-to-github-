    echo -e "  ${CYAN}7)${NC}  Create new repository"
    echo -e "  ${CYAN}8)${NC}  List my repositories"
    echo -e "  ${CYAN}9)${NC}  List repos for specific account"
    echo -e "  ${CYAN}10)${NC} Delete file from repository"
    echo -e "  ${CYAN}11)${NC} Exit"
    echo
    
    read -rp "Enter your choice [1-11]: " choice
    echo
    
    case "$choice" in
        1)
            add_account ""
            ;;
        2)
            list_accounts
            ;;
        3)
            remove_account
            ;;
        4)
            switch_default_account
            ;;
        5)
            interactive_upload
            ;;
        6)
            interactive_list
            ;;
        7)
            interactive_create_repo
            ;;
        8)
            handle_list_repos_menu
            ;;
        9)
            list_repos_for_account
            ;;
        10)
            interactive_delete
            ;;
        11)
            echo -e "${GREEN}Goodbye!${NC}"
            exit 0
            ;;
        *)
            log error "Invalid option"
            ;;
    esac
    
    echo
    read -rp "Press Enter to continue..." 
    show_interactive_menu
}

remove_account() {
    echo -e "${BOLD}Available accounts:${NC}"
    local accounts=()
    local count=0
    
    if [[ -f "$DEFAULT_CONFIG" ]]; then
        echo -e "  ${CYAN}default${NC}: $(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" 2>/dev/null | cut -d= -f2- | tr -d '"')"
        accounts+=("default")
        count=$((count + 1))
    fi
    
    if [[ -d "$ACCOUNTS_DIR" ]]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [[ -f "$cfg" ]] || continue
            local acc
            acc=$(basename "$(dirname "$cfg")")
            local u
            u=$(grep '^GITHUB_USERNAME=' "$cfg" 2>/dev/null | cut -d= -f2- | tr -d '"')
            echo -e "  ${CYAN}$acc${NC}: $u"
            accounts+=("$acc")
            count=$((count + 1))
        done
    fi
    
    if [[ $count -eq 0 ]]; then
        log error "No accounts to remove"
        return
    fi
    
    echo
    read -rp "Enter account name to remove: " acc_name
    
    if [[ -z "$acc_name" ]]; then
        log error "Account name required"
        return
    fi
    
    # Check if it's the default account
    if [[ "$acc_name" == "default" ]]; then
        if [[ -f "$DEFAULT_CONFIG" ]]; then
            rm -f "$DEFAULT_CONFIG"
            log success "Removed default account"
        else
            log error "Default account not found"
        fi
        return
    fi
    
    # Check if account exists in accounts folder
    if [[ -d "$ACCOUNTS_DIR/$acc_name" ]]; then
        # Check if it has a valid username before removing
        local u
        u=$(grep '^GITHUB_USERNAME=' "$ACCOUNTS_DIR/$acc_name/config" 2>/dev/null | cut -d= -f2- | tr -d '"')
        if [[ -z "$u" ]]; then
            echo -e "${YELLOW}Warning: This account has no username saved.${NC}"
            read -rp "Remove anyway? (y/N): " confirm
            [[ "$confirm" =~ ^[Yy]$ ]] || return
        fi
        rm -rf "$ACCOUNTS_DIR/$acc_name"
        log success "Removed account: $acc_name"
    else
        log error "Account not found: $acc_name"
    fi
}

switch_default_account() {
    echo -e "${BOLD}Select account to set as default:${NC}"
    echo
    
    local accounts=()
    local count=1
    local current_user=""
    
    if [[ -f "$DEFAULT_CONFIG" ]]; then
        current_user=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" 2>/dev/null | cut -d= -f2- | tr -d '"')
    fi
    
    # Show current default as option 1
    if [[ -n "$current_user" ]]; then
        echo -e "  ${CYAN}$count)${NC} default: $current_user ${YELLOW}(current)${NC}"
        accounts+=("default|$current_user")
        count=$((count + 1))
    fi
    
    # Show additional accounts, skip if same as default user
    if [[ -d "$ACCOUNTS_DIR" ]]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [[ -f "$cfg" ]] || continue
            local acc
            acc=$(basename "$(dirname "$cfg")")
            local u
            u=$(grep '^GITHUB_USERNAME=' "$cfg" 2>/dev/null | cut -d= -f2- | tr -d '"')
            # Skip if same as current default user or no username
            [[ -z "$u" ]] && continue
            [[ "$u" == "$current_user" ]] && continue
            echo -e "  ${CYAN}$count)${NC} $acc: $u"
            accounts+=("$acc|$u")
            count=$((count + 1))
        done
    fi
    
    if [[ ${#accounts[@]} -eq 0 ]]; then
        log error "No accounts available"
        return
    fi
    
    echo
    read -rp "Select [1-${#accounts[@]}]: " choice
    
    if [[ -z "$choice" ]] || [[ "$choice" -lt 1 ]] || [[ "$choice" -gt ${#accounts[@]} ]]; then
        log error "Invalid selection"
        return
    fi
    
    local selected="${accounts[$((choice - 1))]}"
    local acc_name="${selected%|*}"
    local acc_user="${selected##*|}"
    
    # Copy the selected account config to default
    if [[ "$acc_name" == "default" ]]; then
        log info "Already using default account"
        return
    fi
    
    cp "$ACCOUNTS_DIR/$acc_name/config" "$DEFAULT_CONFIG"
    chmod 600 "$DEFAULT_CONFIG"
    
    log success "Switched default account to: $acc_user"
}

interactive_upload() {
    select_account || return
    
    read -rp "Repository (user/repo or just repo name): " repo
    [[ -z "$repo" ]] && { log error "Repository required"; return; }
    
    read -rp "File path to upload: " file_path
    [[ -z "$file_path" ]] && { log error "File path required"; return; }
    
    if [[ ! -f "$file_path" ]]; then
        log error "File not found: $file_path"
        return
    fi
    
    read -rp "Commit message (optional): " commit_msg
    [[ -z "$commit_msg" ]] && commit_msg="Upload $(basename "$file_path")"
    
    REPO="$repo"
    COMMIT_MSG="$commit_msg"
    FILES=("$file_path")
    do_upload
}

interactive_list() {
    select_account || return
    
    read -rp "Repository (user/repo or just repo name): " repo
    [[ -z "$repo" ]] && { log error "Repository required"; return; }
    
    # Expand repo if needed
    if [[ "$repo" != */* ]]; then
        repo="$GITHUB_USERNAME/$repo"
    fi
    
    # Get files
    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$repo/contents")
    
    if echo "$response" | grep -q '"message"'; then
        log error "Failed to list files"
        return
    fi
    
    echo -e "${BOLD}Files in $repo${NC}:"
    echo "$response" | grep -o '"name": "[^"]*"' | sed 's/"name": "//;s/"$//'
}

interactive_create_repo() {
    select_account || return
    
    read -rp "Repository name: " repo_name
    [[ -z "$repo_name" ]] && { log error "Repository name required"; return; }
    
    read -rp "Description (optional): " description
    
    read -rp "Make private? (y/N): " is_private
    [[ "$is_private" =~ ^[Yy]$ ]] && IS_PRIVATE="true" || IS_PRIVATE="false"
    
    read -rp "Upload a file? (y/N): " upload_file
    if [[ "$upload_file" =~ ^[Yy]$ ]]; then
        read -rp "File path to upload: " file_path
        [[ -z "$file_path" ]] && { log error "File path required"; return; }
        
        if [[ ! -f "$file_path" ]]; then
            log error "File not found: $file_path"
            return
        fi
        
        COMMIT_MSG="Initial commit"
        CREATE_REPO="true"
        REPO="$repo_name"
        REPO_DESCRIPTION="$description"
        FILES=("$file_path")
        do_upload
    else
        CREATE_REPO="true"
        REPO="$repo_name"
        REPO_DESCRIPTION="$description"
        FILES=("README.md")
        COMMIT_MSG="Initial commit"
        do_upload
    fi
}

interactive_delete() {
    select_account || return
    
    read -rp "Repository (user/repo or just repo name): " repo
    [[ -z "$repo" ]] && { log error "Repository required"; return; }
    
    read -rp "File path to delete: " file_path
    [[ -z "$file_path" ]] && { log error "File path required"; return; }
    
    read -rp "Commit message (optional): " commit_msg
    [[ -z "$commit_msg" ]] && commit_msg="Delete $file_path"
    
    REPO="$repo"
    DELETE_FILE="$file_path"
    COMMIT_MSG="$commit_msg"
    do_delete
}

show_help() {
    cat << HELPEOF
╔══════════════════════════════════════════════════════════════════╗
║        GitHub Direct Upload Tool v2.6                         ║
║        Upload files to GitHub WITHOUT cloning!               ║
╚══════════════════════════════════════════════════════════════════╝

USAGE:
    github-upload [options] -r REPO FILE...

OPTIONS:
    -r, --repo REPO           Repository (user/repo or just repo)
    -c, --create              Create repository if it doesn't exist
    -p, --private             Make new repository private
    -d, --description TEXT   Repository description (with -c)
    -m, --message TEXT        Commit message (default: "Upload filename")
    -f, --file-path PATH      Upload file to this path in repo
        
    -A, --add-account [NAME] Add a GitHub account
    -a, --account NAME       Use specific account
    --list-accounts          Show saved accounts
        
--delete PATH            Delete a file from repository
        --list [PATH]            List files in repository
        --list-repos            List your repositories
        --list-branches        List branches in repository
        -b, --branch NAME     Create new branch
        --target-branch       Upload to specific branch
        
    -q, --quiet              Quiet mode (minimal output)
    -P, --progress           Progress bar for uploads
    -n, --dry-run            Show what would be uploaded
    -h, --help               Show this help
        
    --clear                  Clear saved credentials
    --encrypt PASS           Encrypt config file
    --decrypt PASS           Decrypt config file

EXAMPLES:
    # Upload a file
    github-upload -r my-repo -c app.apk
    
    # Upload with custom message
    github-upload -r my-repo -m "Version 2.0" app.apk
    
    # Upload to specific path
    github-upload -r my-repo -f "apps/android/app.apk" app.apk
    
    # Upload multiple files
    github-upload -r my-repo app.apk icon.png readme.txt
    
    # Upload with wildcard
    github-upload -r my-repo '*.apk'
    
    # Create private repo and upload
    github-upload -r my-repo -c -p -d "My app" app.apk
    
    # Delete a file
    github-upload -r my-repo --delete old-file.txt
    
    # List files in repo
    github-upload -r my-repo --list
    
    # Add account
    github-upload -A
    
    # Use specific account
    github-upload -a work -r company/repo file.txt

NOTES:
    • Uses GitHub API directly - NO git clone needed!
    • Max file size: 100MB
    • Files upload to repo root by default
    • Use -f to specify upload path
    • Credentials stored in ~/.config/github-upload/

HELPEOF
}

# ========================
# PARSE ARGUMENTS
# ========================

REPO=""
CREATE_REPO="false"
IS_PRIVATE="false"
REPO_DESCRIPTION=""
COMMIT_MSG=""
FILES=()
SPECIFIED_ACCOUNT=""
DELETE_FILE=""
DO_LIST="false"
LIST_REPOS="false"
LIST_BRANCHES="false"
CREATE_BRANCH="false"
LIST_PATH=""
FILE_PATH=""
BRANCH_NAME=""
SOURCE_BRANCH="main"
TARGET_BRANCH=""
DRY_RUN="false"
QUIET="false"
PROGRESS="false"
SHOW_ACCOUNTS="false"
ADD_ACCOUNT=""
ENCRYPT_CONFIG=""
DECRYPT_CONFIG=""
CLEAR_CREDS="false"
OVERWRITE="false"
INTERACTIVE="false"

# Save original argument count before parsing
ORIGINAL_ARGS=$#

while [[ $# -gt 0 ]]; do
    case "$1" in
        -r|--repo)
            REPO="$2"
            shift 2
            ;;
        -c|--create)
            CREATE_REPO="true"
            shift
            ;;
        -p|--private)
            IS_PRIVATE="true"
            shift
            ;;
        -d|--description)
            REPO_DESCRIPTION="$2"
            shift 2
            ;;
        -m|--message)
            COMMIT_MSG="$2"
            shift 2
            ;;
        -f|--file-path)
            FILE_PATH="$2"
            shift 2
            ;;
        -a|--account)
            SPECIFIED_ACCOUNT="$2"
            shift 2
            ;;
        -A|--add-account)
            ADD_ACCOUNT="${2:-}"
            [[ "$ADD_ACCOUNT" != -* ]] && shift || ADD_ACCOUNT=""
            shift
            ;;
        --list-accounts)
            SHOW_ACCOUNTS="true"
            shift
            ;;
        --delete)
            DELETE_FILE="$2"
            shift 2
            ;;
        --list)
            DO_LIST="true"
            if [[ $# -gt 1 && "$2" != -* ]]; then
                LIST_PATH="$2"
                shift
            fi
            shift
            ;;
        --list-repos)
            LIST_REPOS="true"
            shift
            ;;
        --list-branches)
            LIST_BRANCHES="true"
            shift
            ;;
        -b|--branch)
            CREATE_BRANCH="true"
            BRANCH_NAME="$2"
            shift 2
            ;;
        --source-branch)
            SOURCE_BRANCH="$2"
            shift 2
            ;;
        --target-branch)
            TARGET_BRANCH="$2"
            shift 2
            ;;
        -P|--progress)
            PROGRESS="true"
            shift
            ;;
        --encrypt)
            ENCRYPT_CONFIG="$2"
            shift 2
            ;;
        --decrypt)
            DECRYPT_CONFIG="$2"
            shift 2
            ;;
        -q|--quiet)
            QUIET="true"
            shift
            ;;
        -n|--dry-run)
            DRY_RUN="true"
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        --clear)
            CLEAR_CREDS="true"
            shift
            ;;
        --overwrite)
            OVERWRITE="true"
            shift
            ;;
        -i|--interactive)
            INTERACTIVE="true"
            shift
            ;;
        -*)
            log error "Unknown option: $1"
            exit 1
            ;;
        *)
            FILES+=("$1")
            shift
            ;;
    esac
done

# ========================
# EXECUTE
# ========================

# Check dependencies
for cmd in curl stat; do
    command -v "$cmd" > /dev/null || { log error "Required command '$cmd' not found"; exit 1; }
done

# Handle interactive mode
if [[ "$INTERACTIVE" == "true" ]]; then
    show_interactive_menu
fi

# If no arguments provided, show interactive menu
if [[ $ORIGINAL_ARGS -eq 0 ]]; then
    show_interactive_menu
fi

# Handle --clear
if [[ "$CLEAR_CREDS" == "true" ]]; then
    rm -rf "$CONFIG_DIR"
    log success "Credentials cleared"
    exit 0
fi

# Handle --list-accounts
if [[ "$SHOW_ACCOUNTS" == "true" ]]; then
    list_accounts
    exit 0
fi

# Handle --add-account
if [[ -n "$ADD_ACCOUNT" ]]; then
    add_account "$ADD_ACCOUNT"
    exit 0
fi

# Handle --delete
if [[ -n "$DELETE_FILE" ]]; then
    do_delete
    exit $?
fi

# Handle --list
if [[ "$DO_LIST" == "true" ]]; then
    do_list
    exit $?
fi

# Handle --list-repos
handle_list_repos() {
    . "$DEFAULT_CONFIG" 2>/dev/null || { log error "No account configured"; exit 1; }
    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" "https://api.github.com/user/repos?per_page=100")
    echo -e "${BOLD}Your repositories:${NC}"
    echo "$response" | grep -o '"name": "[^"]*"' | sed 's/"name": "//;s/"$//'
    exit 0
}

if [[ "$LIST_REPOS" == "true" ]]; then
    handle_list_repos
fi

# Handle --list-branches
handle_list_branches() {
    [[ -z "$REPO" ]] && { log error "Repository required"; exit 1; }
    . "$DEFAULT_CONFIG" 2>/dev/null || { log error "No account configured"; exit 1; }
    [[ "$REPO" != */* ]] && REPO="$GITHUB_USERNAME/$REPO"
    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" "https://api.github.com/repos/$REPO/branches")
    echo -e "${BOLD}Branches in $REPO:${NC}"
    echo "$response" | grep -o '"name": "[^"]*"' | sed 's/"name": "//;s/"$//' | head -10
    exit 0
}

if [[ "$LIST_BRANCHES" == "true" ]]; then
    handle_list_branches
fi

# Handle create branch
handle_create_branch() {
    [[ -z "$REPO" ]] && { log error "Repository required"; exit 1; }
    [[ -z "$BRANCH_NAME" ]] && { log error "Branch name required"; exit 1; }
    . "$DEFAULT_CONFIG" 2>/dev/null || { log error "No account configured"; exit 1; }
    [[ "$REPO" != */* ]] && REPO="$GITHUB_USERNAME/$REPO"
    local ref_response
    ref_response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" "https://api.github.com/repos/$REPO/git/refs/heads/$SOURCE_BRANCH")
    local sha
    sha=$(jq_safe "$ref_response" ".object.sha")
    [[ -z "$sha" ]] && { log error "Branch '$SOURCE_BRANCH' not found"; exit 1; }
    local json
    json=$(printf '{"ref":"refs/heads/%s","sha":"%s"}' "$BRANCH_NAME" "$sha")
    local tmpfile
    tmpfile=$(mktemp)
    printf '%s' "$json" > "$tmpfile"
    local resp_code
    resp_code=$(curl -s -w "%{http_code}" -X POST -H "Authorization: Bearer $GITHUB_TOKEN" -H "Accept: application/vnd.github+json" --data-binary "@$tmpfile" "https://api.github.com/repos/$REPO/git/refs" | tail -1)
    rm -f "$tmpfile"
    [[ "$resp_code" == "201" ]] && log success "Branch created: $BRANCH_NAME" || log error "Failed to create branch"
    exit 0
}

if [[ "$CREATE_BRANCH" == "true" ]]; then
    handle_create_branch
fi

# Handle upload
do_upload
