launch_tui() {
    select_account || return

    echo -e "${BOLD}${CYAN}Fetching repositories...${NC}"
    echo

    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" "https://api.github.com/user/repos?per_page=100")

    if echo "$response" | grep -qE '^\{[[:space:]]*"message"'; then
        log error "Failed to fetch repositories"
        return
    fi

    local repo_count=0
    echo -e "${BOLD}${MAGENTA}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}${MAGENTA}║        📁 REPOSITORIES FOR $GITHUB_USERNAME              ║${NC}"
    echo -e "${BOLD}${MAGENTA}╚══════════════════════════════════════════════════════════╝${NC}"
    echo

    local repo_names=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && repo_names+=("$line")
    done < <(echo "$response" | grep -o '"name": "[^"]*"' | sed 's/"name": "//;s/"$//')

    read -rp "Show all files in each repo? (y/N): " show_all
    [[ "$show_all" =~ ^[Yy]$ ]] || show_all="n"

    for repo_name in "${repo_names[@]}"; do
        repo_count=$((repo_count + 1))
        echo -e "${GREEN}┌─ 📂 $repo_name${NC}"

        local files_response
        files_response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
            "https://api.github.com/repos/$GITHUB_USERNAME/$repo_name/contents")

        if echo "$files_response" | grep -q '"name"'; then
            local file_count=0
            local file_names=()
            while IFS= read -r file; do
                [[ -n "$file" ]] && file_names+=("$file") && file_count=$((file_count + 1))
            done < <(echo "$files_response" | grep -o '"name": "[^"]*"' | sed 's/"name": "//;s/"$//')

            if [[ $file_count -eq 0 ]]; then
                echo -e "${DIM}│   (empty)${NC}"
            else
                local max_show=5
                [[ "$show_all" =~ ^[Yy]$ ]] && max_show=100

                for i in "${!file_names[@]}"; do
                    if [[ $i -lt $max_show ]]; then
                        local emoji
                        emoji=$(get_file_emoji "${file_names[$i]}")
                        if [[ $i -eq $((file_count - 1)) ]] || [[ $i -eq $((max_show - 1)) ]]; then
                            echo -e "${DIM}└── $emoji ${file_names[$i]}${NC}"
                        else
                            echo -e "${DIM}├── $emoji ${file_names[$i]}${NC}"
                        fi
                    fi
                done
                if [[ $file_count -gt $max_show ]]; then
                    echo -e "${YELLOW}└── ... and $((file_count - max_show)) more files${NC}"
                fi
            fi
        fi
        echo "│"
    done

    echo -e "${BOLD}${GREEN}Total: $repo_count repositories${NC}"
}

