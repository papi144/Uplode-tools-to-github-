remove_account() {
    echo -e "${BOLD}Available accounts:${NC}"
    local accounts=()
    local count=0

    if [[ -f "$DEFAULT_CONFIG" ]]; then
        echo -e "  ${CYAN}default${NC}: $(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" 2>/dev/null | cut -d= -f2- | tr -d '"')"
        accounts+=("default")
        count=$((count + 1))
    fi

    if [[ -d "$ACCOUNTS_DIR" ]]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [[ -f "$cfg" ]] || continue
            local acc
            acc=$(basename "$(dirname "$cfg")")
            local u
            u=$(grep '^GITHUB_USERNAME=' "$cfg" 2>/dev/null | cut -d= -f2- | tr -d '"')
            echo -e "  ${CYAN}$acc${NC}: $u"
            accounts+=("$acc")
            count=$((count + 1))
        done
    fi

    if [[ $count -eq 0 ]]; then
        log error "No accounts to remove"
        return
    fi

    echo
    read -rp "Enter account name to remove: " acc_name
    [[ -z "$acc_name" ]] && { log error "Account name required"; return; }

    if [[ "$acc_name" == "default" ]]; then
        if [[ -f "$DEFAULT_CONFIG" ]]; then
            rm -f "$DEFAULT_CONFIG"
            log success "Removed default account"
        else
            log error "Default account not found"
        fi
        return
    fi

    if [[ -d "$ACCOUNTS_DIR/$acc_name" ]]; then
        local u
        u=$(grep '^GITHUB_USERNAME=' "$ACCOUNTS_DIR/$acc_name/config" 2>/dev/null | cut -d= -f2- | tr -d '"')
        if [[ -z "$u" ]]; then
            echo -e "${YELLOW}Warning: This account has no username saved.${NC}"
            read -rp "Remove anyway? (y/N): " confirm
            [[ "$confirm" =~ ^[Yy]$ ]] || return
        fi
        rm -rf "$ACCOUNTS_DIR/$acc_name"
        log success "Removed account: $acc_name"
    else
        log error "Account not found: $acc_name"
    fi
}

switch_default_account() {
    echo -e "${BOLD}Select account to set as default:${NC}"
    echo

    local accounts=()
    local count=1
    local current_user=""

    if [[ -f "$DEFAULT_CONFIG" ]]; then
        current_user=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" 2>/dev/null | cut -d= -f2- | tr -d '"')
    fi

    if [[ -n "$current_user" ]]; then
        echo -e "  ${CYAN}$count)${NC} default: $current_user ${YELLOW}(current)${NC}"
        accounts+=("default|$current_user")
        count=$((count + 1))
    fi

    if [[ -d "$ACCOUNTS_DIR" ]]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [[ -f "$cfg" ]] || continue
            local acc
            acc=$(basename "$(dirname "$cfg")")
            local u
            u=$(grep '^GITHUB_USERNAME=' "$cfg" 2>/dev/null | cut -d= -f2- | tr -d '"')
            [[ -z "$u" ]] && continue
            [[ "$u" == "$current_user" ]] && continue
            echo -e "  ${CYAN}$count)${NC} $acc: $u"
            accounts+=("$acc|$u")
            count=$((count + 1))
        done
    fi

    if [[ ${#accounts[@]} -eq 0 ]]; then
        log error "No accounts available"
        return
    fi

    echo
    read -rp "Select [1-${#accounts[@]}]: " choice

    if [[ -z "$choice" ]] || ! [[ "$choice" =~ ^[0-9]+$ ]] \
        || [[ "$choice" -lt 1 ]] || [[ "$choice" -gt ${#accounts[@]} ]]; then
        log error "Invalid selection"
        return
    fi

    local selected="${accounts[$((choice - 1))]}"
    local acc_name="${selected%|*}"
    local acc_user="${selected##*|}"

    if [[ "$acc_name" == "default" ]]; then
        log info "Already using default account"
        return
    fi

    cp "$ACCOUNTS_DIR/$acc_name/config" "$DEFAULT_CONFIG"
    chmod 600 "$DEFAULT_CONFIG"

    # FIX #13: Re-source the new config so current session reflects the switch
    source "$DEFAULT_CONFIG"

    log success "Switched default account to: $acc_user"
}

