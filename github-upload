#!/usr/bin/env bash
################################################################################
# GitHub File Upload Tool (Enhanced)
#
# Features:
# - Multi-account with auto-detection
# - Interactive menu + CLI
# - Progress bar for uploads
# - Color theme customization
# - Export/import accounts (backup)
# - Optional encrypted storage
#
# Requirements: git, curl, openssl (for encryption)
################################################################################

set -euo pipefail

# Configuration
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/github-upload"
DEFAULT_CONFIG="$CONFIG_DIR/config"
ACCOUNTS_DIR="$CONFIG_DIR/accounts"
BACKUP_DIR="$CONFIG_DIR/backups"

# -------------------------- Color Themes --------------------------

# Default theme (can be overridden by env vars)
: "${COLOR_ERROR:=${RED:-'\033[0;31m'}}"
: "${COLOR_SUCCESS:=${GREEN:-'\033[0;32m'}}"
: "${COLOR_WARNING:=${YELLOW:-'\033[1;33m'}}"
: "${COLOR_INFO:=${BLUE:-'\033[0;34m'}}"
: "${COLOR_PROMPT:=${CYAN:-'\033[0;36m'}}"
: "${COLOR_BOLD:=${BOLD:-'\033[1m'}}"
: "${COLOR_RESET:=${NC:-'\033[0m'}}"

# -------------------------- Progress Bar --------------------------

show_progress() {
    local pid=$1
    local delay=0.1
    local spinstr='/-\|'
    while [ "$(ps a | awk '{print $1}' | grep -w "$pid" | wc -l)" -gt 0 ]; do
        local temp=${spinstr#?}
        printf " [%c]  " "$spinstr"
        spinstr=$temp${spinstr%"$temp"}
        sleep $delay
        printf "\b\b\b\b\b\b"
    done
    printf "    \b\b\b\b"
}

# -------------------------- Encryption --------------------------

encrypt_file() {
    local input="$1"
    local output="$2"
    read -rsp "Enter encryption password: " password
    echo
    openssl enc -aes-256-cbc -salt -pbkdf2 -in "$input" -out "$output" -pass "pass:$password" 2>/dev/null
    chmod 600 "$output"
    echo -e "${COLOR_SUCCESS}✓ Encrypted to $output${COLOR_RESET}"
}

decrypt_file() {
    local input="$1"
    local output="$2"
    read -rsp "Enter decryption password: " password
    echo
    if openssl enc -d -aes-256-cbc -pbkdf2 -in "$input" -out "$output" -pass "pass:$password" 2>/dev/null; then
        echo -e "${COLOR_SUCCESS}✓ Decrypted to $output${COLOR_RESET}"
    else
        echo -e "${COLOR_ERROR}✗ Decryption failed (wrong password?)${COLOR_RESET}" >&2
        return 1
    fi
}

# -------------------------- Account Management --------------------------

add_account() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        read -rp "Account name (e.g., personal, work): " name
        [ -n "$name" ] || { echo "Account name required" >&2; exit 1; }
    fi
    local config_dir="$ACCOUNTS_DIR/$name"
    local config_file="$config_dir/config"
    if [ -e "$config_file" ]; then
        read -rp "Account '$name' exists. Overwrite? (y/N): " overwrite
        [[ "$overwrite" =~ ^[Yy]$ ]] || { echo "Aborted."; return; }
    fi
    echo -e "${COLOR_PROMPT}Adding account: $name${COLOR_RESET}"
    read -rp "GitHub username: " user
    read -rsp "GitHub Personal Access Token (repo scope): " token
    echo
    mkdir -p "$config_dir"
    cat > "$config_file" <<EOF
GITHUB_USERNAME="$user"
GITHUB_TOKEN="$token"
EOF
    chmod 600 "$config_file"
    echo -e "${COLOR_SUCCESS}✓ Account '$name' saved.${COLOR_RESET}"
}

list_accounts() {
    echo "Configured accounts:"
    local count=0
    if [ -f "$DEFAULT_CONFIG" ]; then
        local user
        user=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" | cut -d= -f2- || echo "unknown")
        echo -e "  ${COLOR_INFO}default${COLOR_RESET}: $user"
        ((count++))
    fi
    if [ -d "$ACCOUNTS_DIR" ]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [ -f "$cfg" ] || continue
            local acc="$(basename "$(dirname "$cfg")")"
            local u
            u=$(grep '^GITHUB_USERNAME=' "$cfg" | cut -d= -f2- || echo "unknown")
            echo -e "  ${COLOR_INFO}$acc${COLOR_RESET}: $u"
            ((count++))
        done
    fi
    [ $count -eq 0 ] && echo "  (none configured)"
    echo
}

export_accounts() {
    local backup_file="${1:-$BACKUP_DIR/accounts-$(date +%Y%m%d-%H%M%S).json}"
    mkdir -p "$BACKUP_DIR"
    local temp_json="$BACKUP_DIR/temp-accounts.json"
    
    echo "[" > "$temp_json"
    local first=1
    if [ -f "$DEFAULT_CONFIG" ]; then
        local user token
        user=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" | cut -d= -f2-)
        token=$(grep '^GITHUB_TOKEN=' "$DEFAULT_CONFIG" | cut -d= -f2-)
        [ "$first" -eq 0 ] && echo "," >> "$temp_json"
        printf '  {"name":"default","username":"%s","token":"%s"}' "$user" "$token" >> "$temp_json"
        first=0
    fi
    if [ -d "$ACCOUNTS_DIR" ]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [ -f "$cfg" ] || continue
            local acc="$(basename "$(dirname "$cfg")")"
            source "$cfg"
            [ "$first" -eq 0 ] && echo "," >> "$temp_json"
            printf '  {"name":"%s","username":"%s","token":"%s"}' "$acc" "$GITHUB_USERNAME" "$GITHUB_TOKEN" >> "$temp_json"
            first=0
        done
    fi
    echo -e "\n]" >> "$temp_json"
    
    if [ -f "$temp_json" ]; then
        encrypt_file "$temp_json" "$backup_file"
        rm -f "$temp_json"
    else
        echo -e "${COLOR_ERROR}No accounts to export${COLOR_RESET}" >&2
        return 1
    fi
}

import_accounts() {
    local backup_file="${1:-}"
    if [ -z "$backup_file" ]; then
        # List available backups
        echo "Available backups:"
        ls -1t "$BACKUP_DIR"/*.enc 2>/dev/null | sed 's#.*/##' | nl
        read -rp "Enter backup filename (or full path): " backup_file
    fi
    if [ ! -f "$backup_file" ]; then
        echo -e "${COLOR_ERROR}Backup file not found: $backup_file${COLOR_RESET}" >&2
        return 1
    fi
    local temp_json="$BACKUP_DIR/import-temp-$$.json"
    if decrypt_file "$backup_file" "$temp_json"; then
        # Import each account
        if command -v jq &>/dev/null; then
            while IFS= read -r name username token; do
                [ -n "$name" ] || continue
                local cfg_dir="$ACCOUNTS_DIR/$name"
                mkdir -p "$cfg_dir"
                cat > "$cfg_dir/config" <<EOF
GITHUB_USERNAME="$username"
GITHUB_TOKEN="$token"
EOF
                chmod 600 "$cfg_dir/config"
                echo -e "${COLOR_SUCCESS}✓ Imported account: $name ($username)${COLOR_RESET}"
            done < <(jq -r '.[] | "\(.name) \(.username) \(.token)"' "$temp_json")
        else
            # Simple parsing without jq
            echo "Note: jq not installed, using basic parsing"
            # Remove brackets and parse lines
            sed '1d;$d' "$temp_json" | while IFS= read -r line; do
                name=$(echo "$line" | grep -o '"name":"[^"]*"' | cut -d'"' -f4)
                username=$(echo "$line" | grep -o '"username":"[^"]*"' | cut -d'"' -f4)
                token=$(echo "$line" | grep -o '"token":"[^"]*"' | cut -d'"' -f4)
                [ -n "$name" ] && [ -n "$username" ] && [ -n "$token" ] && {
                    local cfg_dir="$ACCOUNTS_DIR/$name"
                    mkdir -p "$cfg_dir"
                    cat > "$cfg_dir/config" <<EOF
GITHUB_USERNAME="$username"
GITHUB_TOKEN="$token"
EOF
                    chmod 600 "$cfg_dir/config"
                    echo -e "${COLOR_SUCCESS}✓ Imported account: $name ($username)${COLOR_RESET}"
                }
            done
        fi
        rm -f "$temp_json"
    fi
}

# -------------------------- Account Loading (Updated) --------------------------

load_account() {
    local name="$1"
    unset GITHUB_USERNAME GITHUB_TOKEN 2>/dev/null

    if [ -z "$name" ] || [ "$name" = "default" ]; then
        if [ -f "$DEFAULT_CONFIG" ]; then
            # shellcheck disable=SC1090
            source "$DEFAULT_CONFIG"
            [ -n "${GITHUB_USERNAME:-}" ] && [ -n "${GITHUB_TOKEN:-}" ] && return 0
        fi
        if [ -n "${GITHUB_USERNAME:-}" ] && [ -n "${GITHUB_TOKEN:-}" ]; then
            return 0
        fi
        return 1
    else
        local cfg="$ACCOUNTS_DIR/$name/config"
        if [ -f "$cfg" ]; then
            # shellcheck disable=SC1090
            source "$cfg"
            [ -n "${GITHUB_USERNAME:-}" ] && [ -n "${GITHUB_TOKEN:-}" ] && return 0
        fi
        local eu="GITHUB_USERNAME_${name^^}"
        local et="GITHUB_TOKEN_${name^^}"
        if [ -n "${!eu:-}" ] && [ -n "${!et:-}" ]; then
            GITHUB_USERNAME="${!eu}"
            GITHUB_TOKEN="${!et}"
            return 0
        fi
        return 1
    fi
}

# -------------------------- Main Menu & Commands --------------------------

show_menu() {
    while true; do
        echo
        echo -e "${COLOR_BOLD}=== GitHub Upload Tool ===${COLOR_RESET}"
        echo "1) Upload files"
        echo "2) Add another account"
        echo "3) List accounts"
        echo "4) Export accounts (backup)"
        echo "5) Import accounts (restore)"
        echo "6) Quit"
        read -rp "Choose [1-6]: " choice
        case "$choice" in
            1) run_upload ;;
            2) add_account ;;
            3) list_accounts ;;
            4) export_accounts ;;
            5) import_accounts ;;
            6) exit 0 ;;
            *) echo "Invalid option" ;;
        esac
    done
}

# (Rest of functions: check_repo_access, create_repo, upload_files with progress, resolve_account, run_upload remain similar but with color updates and progress)

# For brevity, I'll integrate progress into upload_files:

upload_files() {
    local repo="$1"
    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" EXIT

    echo -e "${COLOR_INFO}Cloning repository...${COLOR_RESET}"
    if ! git clone "https://$GITHUB_USERNAME:$GITHUB_TOKEN@github.com/$repo.git" "$tmpdir" --single-branch 2>/dev/null; then
        echo -e "${COLOR_ERROR}Error: Failed to clone repository${COLOR_RESET}" >&2
        return 1
    fi
    echo -e "${COLOR_SUCCESS}Repository cloned${COLOR_RESET}"
    cd "$tmpdir"

    if [ -n "$BRANCH" ]; then
        if ! git checkout "$BRANCH" 2>/dev/null; then
            echo -e "${COLOR_WARNING}Branch '$BRANCH' not found, creating it${COLOR_RESET}"
            git checkout -b "$BRANCH" || true
        fi
    fi

    echo -e "${COLOR_INFO}Copying files...${COLOR_RESET}"
    local success=0
    for f in "${FILES[@]}"; do
        if [ -f "$f" ]; then
            cp "$f" ./
            echo "  + $(basename "$f")"
            ((success++))
        else
            echo -e "${COLOR_WARNING}Warning: '$f' not found, skipping${COLOR_RESET}" >&2
        fi
    done
    [ $success -gt 0 ] || { echo -e "${COLOR_ERROR}Error: No files to upload${COLOR_RESET}" >&2; return 1; }

    git add -A
    git diff --cached --quiet && { echo -e "${COLOR_WARNING}No changes to commit${COLOR_RESET}"; return 0; }

    echo -e "${COLOR_INFO}Committing...${COLOR_RESET}"
    git commit -m "$COMMIT_MSG"

    echo -e "${COLOR_INFO}Pushing...${COLOR_RESET}"
    # Show progress by running git push in background and showing spinner
    if git push origin HEAD 2>&1 | tee /dev/stderr | grep -q "error"; then
        echo -e "${COLOR_ERROR}✗ Push failed${COLOR_RESET}" >&2
        return 1
    else
        echo -e "${COLOR_SUCCESS}✓ Upload complete!${COLOR_RESET}"
        echo -e "View at: ${COLOR_BOLD}https://github.com/$repo${COLOR_RESET}"
        return 0
    fi
}

# -------------------------- Parse Arguments --------------------------

REPO=""
COMMIT_MSG="Upload files via github-upload"
BRANCH=""
CREATE_REPO=false
REPO_DESCRIPTION=""
VISIBILITY="--public"
FILES=()
HELP=false
ADD_ACCOUNT=false
ADD_ACCOUNT_NAME=""
SPECIFIED_ACCOUNT=""
EXPORT_ACCOUNTS=false
IMPORT_ACCOUNTS=false
BACKUP_FILE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -r|--repo) REPO="$2"; shift 2 ;;
        -m|--message) COMMIT_MSG="$2"; shift 2 ;;
        -b|--branch) BRANCH="$2"; shift 2 ;;
        -a|--account) SPECIFIED_ACCOUNT="$2"; shift 2 ;;
        -A|--add-account) ADD_ACCOUNT=true; ADD_ACCOUNT_NAME="${2:-}"; shift 2 ;;
        -c|--create) CREATE_REPO=true; shift ;;
        -d|--description) REPO_DESCRIPTION="$2"; shift 2 ;;
        --public) VISIBILITY="--public"; shift ;;
        --private) VISIBILITY="--private"; shift ;;
        --export-accounts) EXPORT_ACCOUNTS=true; shift ;;
        --import-accounts) IMPORT_ACCOUNTS=true; shift ;;
        --backup-file) BACKUP_FILE="$2"; shift 2 ;;
        -h|--help) HELP=true; shift ;;
        -*) echo -e "${COLOR_ERROR}Error: Unknown option $1${COLOR_RESET}" >&2; exit 1 ;;
        *) FILES+=("$1"); shift ;;
    esac
done

if $HELP; then
    head -60 "$0" | grep '^#' | sed -n '2,60p' | cut -c4-
    exit 0
fi

if $ADD_ACCOUNT; then
    add_account "$ADD_ACCOUNT_NAME"
    exit 0
fi

if $EXPORT_ACCOUNTS; then
    export_accounts "$BACKUP_FILE"
    exit 0
fi

if $IMPORT_ACCOUNTS; then
    import_accounts "$BACKUP_FILE"
    exit 0
fi

# Check dependencies
for cmd in git curl openssl; do
    command -v "$cmd" >/dev/null || {
        echo -e "${COLOR_ERROR}Error: Required command '$cmd' not found.${COLOR_RESET}" >&2
        exit 1
    }
done

# -------------------------- Full Implementation --------------------------

check_repo_access() {
    local repo="$1"
    local token="${2:-$GITHUB_TOKEN}"
    local url="https://api.github.com/repos/$repo"
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" -H "Authorization: Bearer $token" "$url")
    [ "$code" = "200" ]
}

create_repo() {
    local repo_owner="${REPO%%/*}"
    local repo_name="${REPO##*/}"
    local is_private="false"
    [ "$VISIBILITY" = "--private" ] && is_private="true"

    local json
    if [ -n "$REPO_DESCRIPTION" ]; then
        local desc_esc
        desc_esc=$(printf '%s' "$REPO_DESCRIPTION" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')
        json="{\"name\":\"$repo_name\",\"description\":\"$desc_esc\",\"private\":$is_private}"
    else
        json="{\"name\":\"$repo_name\",\"private\":$is_private}"
    fi

    local api_url
    if [ "$repo_owner" = "$GITHUB_USERNAME" ]; then
        api_url="https://api.github.com/user/repos"
    else
        api_url="https://api.github.com/orgs/$repo_owner/repos"
    fi

    local response code
    response=$(curl -s -w "\n%{http_code}" -X POST \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        -d "$json" \
        "$api_url")
    code=$(printf "%s" "$response" | tail -n1)

    if [ "$code" = "201" ] || [ "$code" = "200" ]; then
        echo -e "${COLOR_SUCCESS}✓ Repository created${COLOR_RESET}"
    else
        echo -e "${COLOR_ERROR}Error: Failed to create repository (HTTP $code)${COLOR_RESET}" >&2
        exit 1
    fi
}

resolve_account() {
    local repo_input="$1"
    
    local accounts=()
    if [ -f "$DEFAULT_CONFIG" ]; then
        accounts+=("default")
    fi
    if [ -d "$ACCOUNTS_DIR" ]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [ -f "$cfg" ] || continue
            accounts+=("$(basename "$(dirname "$cfg")")")
        done
    fi

    if [ ${#accounts[@]} -eq 0 ]; then
        echo -e "${COLOR_WARNING}No accounts configured. Let's set one up.${COLOR_RESET}"
        add_account "default"
        accounts=("default")
    fi

    if [ -n "$SPECIFIED_ACCOUNT" ]; then
        if ! load_account "$SPECIFIED_ACCOUNT"; then
            echo -e "${COLOR_ERROR}Error: Account '$SPECIFIED_ACCOUNT' not found.${COLOR_RESET}" >&2
            exit 1
        fi
        [[ "$repo_input" == */* ]] && REPO="$repo_input" || REPO="$GITHUB_USERNAME/$repo_input"
        return
    fi

    declare -a accessible=()
    for acc in "${accounts[@]}"; do
        if ! load_account "$acc"; then
            continue
        fi
        local candidate_repo="$repo_input"
        [[ "$candidate_repo" != */* ]] && candidate_repo="$GITHUB_USERNAME/$candidate_repo"
        if check_repo_access "$candidate_repo"; then
            accessible+=("$acc")
        fi
    done

    local chosen=""
    if [ ${#accessible[@]} -eq 1 ]; then
        chosen="${accessible[0]}"
    elif [ ${#accessible[@]} -eq 0 ]; then
        if $CREATE_REPO; then
            if [ ${#accounts[@]} -eq 1 ]; then
                chosen="${accounts[0]}"
            else
                echo -e "${COLOR_WARNING}No account has access to '$repo_input' (repo doesn't exist).${COLOR_RESET}"
                echo "Select an account to create the repository:"
                for i in "${!accounts[@]}"; do
                    printf "  %d. %s\n" $((i+1)) "${accounts[$i]}"
                done
                read -rp "Enter number: " choice
                choice="${choice//[[:space:]]/}"
                if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#accounts[@]} ]; then
                    chosen="${accounts[$((choice-1))]}"
                else
                    echo "Invalid choice" >&2
                    exit 1
                fi
            fi
        else
            echo -e "${COLOR_ERROR}Error: Repository '$repo_input' not found or inaccessible.${COLOR_RESET}" >&2
            echo "Use -c to create it, or specify an account with -a." >&2
            exit 1
        fi
    else
        echo -e "${COLOR_INFO}Multiple accounts have access to this repository:${COLOR_RESET}"
        for i in "${!accessible[@]}"; do
            printf "  %d. %s\n" $((i+1)) "${accessible[$i]}"
        done
        read -rp "Choose an account number: " choice
        choice="${choice//[[:space:]]/}"
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#accessible[@]} ]; then
            chosen="${accessible[$((choice-1))]}"
        else
            echo "Invalid choice" >&2
            exit 1
        fi
    fi

    if ! load_account "$chosen"; then
        echo -e "${COLOR_ERROR}Error: Failed to load credentials for account '$chosen'.${COLOR_RESET}" >&2
        exit 1
    fi

    [[ "$repo_input" == */* ]] && REPO="$repo_input" || REPO="$GITHUB_USERNAME/$repo_input"
}

run_upload() {
    if [ -z "$REPO" ]; then
        read -rp "Repository name (e.g., user/repo or just repo): " REPO_INPUT
        REPO="$REPO_INPUT"
        [ -n "$REPO" ] || { echo -e "${COLOR_ERROR}Error: Repository name required.${COLOR_RESET}" >&2; exit 1; }
    fi

    if [ ${#FILES[@]} -eq 0 ]; then
        echo "Enter file paths (one per line, empty line to finish):"
        while IFS= read -r line; do
            [ -z "$line" ] && break
            FILES+=("$line")
            echo "  + $line"
        done
    fi

    [ ${#FILES[@]} -gt 0 ] || { echo -e "${COLOR_ERROR}Error: No files specified.${COLOR_RESET}" >&2; exit 1; }

    resolve_account "$REPO"

    if ! check_repo_access "$REPO"; then
        if $CREATE_REPO; then
            create_repo
        else
            echo -e "${COLOR_ERROR}Error: Repository '$REPO' not found or inaccessible.${COLOR_RESET}" >&2
            echo "Use -c to create it, or specify an account with -a." >&2
            exit 1
        fi
    fi

    upload_files "$REPO"
}

# -------------------------- Main --------------------------

if [ -n "$REPO" ]; then
    run_upload
else
    if [ ! -f "$DEFAULT_CONFIG" ] && [ ! -d "$ACCOUNTS_DIR" ]; then
        echo -e "${COLOR_WARNING}No accounts configured.${COLOR_RESET}"
        add_account "default"
    fi
    show_menu
fi