#!/usr/bin/env bash
################################################################################
# GitHub Direct Upload Tool
#
# Upload files directly to GitHub via API (NO CLONING NEEDED!)
# Features: No clone, 100MB support, quiet mode, fixed help, delete files
################################################################################

set -euo pipefail

# ========================
# CONFIGURATION
# ========================

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/github-upload"
DEFAULT_CONFIG="$CONFIG_DIR/config"
ACCOUNTS_DIR="$CONFIG_DIR/accounts"
MAX_FILE_SIZE=104857600  # 100MB in bytes

# Modern Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
ORANGE='\033[38;5;208m'
PURPLE='\033[38;5;141m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# Icons
CHECK="${GREEN}[+]"
CROSS="${RED}[x]"
ARROW="${CYAN}->"
BULLET="${ORANGE}*"

# ========================
# HELPER FUNCTIONS
# ========================

log() {
    local type="$1"
    shift
    local msg="$*"
    
    case "$type" in
        info)    [[ "$QUIET" != "true" ]] && echo -e "${CYAN}[i]${NC} $msg" ;;
        success) [[ "$QUIET" != "true" ]] && echo -e "${GREEN}${CHECK}${NC} $msg" ;;
        warn)    [[ "$QUIET" != "true" ]] && echo -e "${YELLOW}[!]${NC} $msg" ;;
        error)   echo -e "${RED}${CROSS}${NC} $msg" >&2 ;;
        quiet)   : ;;  # Silent
    esac
}

jq_safe() {
    local json="$1"
    local query="$2"
    if command -v jq > /dev/null 2>&1; then
        echo "$json" | jq -r "$query" 2>/dev/null || echo ""
    else
        if [[ "$query" == ".sha" ]]; then
            echo "$json" | grep -o '"sha":"[^"]*"' | head -1 | cut -d'"' -f4
        elif [[ "$query" == ".message" ]]; then
            echo "$json" | grep -o '"message":"[^"]*"' | head -1 | cut -d'"' -f4
        else
            echo "$json" | grep -o '"name":"[^"]*"' | head -1 | cut -d'"' -f4
        fi
    fi
}

handle_list_repos_menu() {
    . "$DEFAULT_CONFIG" 2>/dev/null || { log error "No account configured"; return; }
    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" "https://api.github.com/user/repos?per_page=100")
    echo -e "${BOLD}Your repositories:${NC}"
    echo "$response" | grep -o '"name": "[^"]*"' | sed 's/"name": "//;s/"$//'
}

list_repos_for_account() {
    select_account || return
    
    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" "https://api.github.com/user/repos?per_page=100")
    echo -e "${BOLD}Repositories for $GITHUB_USERNAME:${NC}"
    echo "$response" | grep -o '"name": "[^"]*"' | sed 's/"name": "//;s/"$//'
}

show_progress() {
    local current=$1
    local total=$2
    local file=$3
    local percent=$((current * 100 / total))
    local hashes=$((percent / 2))
    local spaces=$((50 - hashes))
    printf "\r${GREEN}[%-${spaces}s${NC}] %3d%% %s" "$(printf '#%.0s' $(seq 1 $hashes) 2>/dev/null || echo -n '')" "$percent" "$(basename "$file")"
}

get_mime_type() {
    local file="$1"
    local ext="${file##*.}"
    case "$ext" in
        apk) echo "application/vnd.android.package-archive" ;;
        ipa) echo "application/iphone" ;;
        jar) echo "application/java-archive" ;;
        zip) echo "application/zip" ;;
        tar) echo "application/x-tar" ;;
        gz) echo "application/gzip" ;;
        pdf) echo "application/pdf" ;;
        txt) echo "text/plain" ;;
        json) echo "application/json" ;;
        xml) echo "application/xml" ;;
        html) echo "text/html" ;;
        js) echo "application/javascript" ;;
        sh) echo "application/x-sh" ;;
        py) echo "text/x-python" ;;
        md) echo "text/markdown" ;;
        png) echo "image/png" ;;
        jpg) echo "image/jpeg" ;;
        gif) echo "image/gif" ;;
        svg) echo "image/svg+xml" ;;
        mp3) echo "audio/mpeg" ;;
        mp4) echo "video/mp4" ;;
        *) echo "application/octet-stream" ;;
    esac
}

# ========================
# ACCOUNT MANAGEMENT
# ========================

add_account() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        read -rp "Account name (e.g., personal, work): " name
        [[ -n "$name" ]] || { echo "Account name required"; exit 1; }
    fi
    
    local config_dir="$ACCOUNTS_DIR/$name"
    local config_file="$config_dir/config"
    
    if [[ -e "$config_file" && "${OVERWRITE:-}" != "true" ]]; then
        read -rp "Account '$name' exists. Overwrite? (y/N): " overwrite
        [[ "$overwrite" =~ ^[Yy]$ ]] || { echo "Aborted."; return; }
    fi
    
    echo -e "${CYAN}Adding account: $name${NC}"
    read -rp "GitHub username: " user
    read -rsp "GitHub Personal Access Token: " token
    echo
    
    mkdir -p "$config_dir"
    cat > "$config_file" <<EOF
GITHUB_USERNAME="$user"
GITHUB_TOKEN="$token"
EOF
    chmod 600 "$config_file"
    echo -e "${GREEN}${CHECK} Account '${name}' saved.${NC}"
}

list_accounts() {
    echo "Configured accounts:"
    local count=0
    local current_user=""
    
    # Load default account to check which one is active
    if [[ -f "$DEFAULT_CONFIG" ]]; then
        . "$DEFAULT_CONFIG" 2>/dev/null
        current_user="${GITHUB_USERNAME:-}"
    fi
    
    # Show default account
    if [[ -f "$DEFAULT_CONFIG" ]]; then
        local user
        user=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" 2>/dev/null | cut -d= -f2- | tr -d '"' || echo "unknown")
        echo -e "  ${BLUE}default${NC}: $user ${GREEN}(you are here)${NC}"
        count=$((count + 1))
    fi
    
    # Show additional accounts from accounts folder
    if [[ -d "$ACCOUNTS_DIR" ]]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [[ -f "$cfg" ]] || continue
            local acc
            acc=$(basename "$(dirname "$cfg")")
            local u
            u=$(grep '^GITHUB_USERNAME=' "$cfg" 2>/dev/null | cut -d= -f2- | tr -d '"' || echo "unknown")
            echo -e "  ${BLUE}$acc${NC}: $u"
            count=$((count + 1))
        done
    fi
    
    [[ $count -eq 0 ]] && echo "  (none configured)"
    echo
}

load_account() {
    local name="$1"
    unset GITHUB_USERNAME GITHUB_TOKEN 2>/dev/null
    
    if [[ -n "${GITHUB_TOKEN:-}" ]]; then
        return 0
    fi
    
    if [[ -z "$name" ]] || [[ "$name" == "default" ]]; then
        if [[ -f "$DEFAULT_CONFIG" ]]; then
            # shellcheck disable=SC1090
            source "$DEFAULT_CONFIG"
        fi
        [[ -n "${GITHUB_USERNAME:-}" && -n "${GITHUB_TOKEN:-}" ]] && return 0
        return 1
    else
        local cfg="$ACCOUNTS_DIR/$name/config"
        if [[ -f "$cfg" ]]; then
            # shellcheck disable=SC1090
            source "$cfg"
        fi
        [[ -n "${GITHUB_USERNAME:-}" && -n "${GITHUB_TOKEN:-}" ]] && return 0
        return 1
    fi
}

verify_account() {
    local response
    response=$(curl -s -w "\n%{http_code}" -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/user")
    local code
    code=$(echo "$response" | tail -n1)
    
    if [[ "$code" == "200" ]]; then
        local username
        username=$(echo "$response" | grep -o '"login":"[^"]*"' | head -1 | cut -d'"' -f4)
        echo "$username"
        return 0
    fi
    return 1
}

# ========================
# REPO OPERATIONS
# ========================

check_repo() {
    local repo="$1"
    local response
    response=$(curl -s -w "\n%{http_code}" -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$repo")
    local code
    code=$(echo "$response" | tail -n1)
    echo "$code"
}

create_repo() {
    local repo_owner="$1"
    local repo_name="$2"
    local is_private="${3:-false}"
    local description="${4:-}"
    
    local json
    if [[ -n "$description" ]]; then
        json="{\"name\":\"$repo_name\",\"description\":\"$description\",\"private\":$is_private}"
    else
        json="{\"name\":\"$repo_name\",\"private\":$is_private}"
    fi
    
    local api_url
    if [[ "$repo_owner" == "$GITHUB_USERNAME" ]]; then
        api_url="https://api.github.com/user/repos"
    else
        api_url="https://api.github.com/orgs/$repo_owner/repos"
    fi
    
    local response code
    response=$(curl -s -w "\n%{http_code}" -X POST \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        -d "$json" \
        "$api_url")
    code=$(echo "$response" | tail -n1)
    
    if [[ "$code" == "201" ]] || [[ "$code" == "200" ]]; then
        log success "Repository created"
        return 0
    else
        local msg
        msg=$(echo "$response" | grep -o '"message":"[^"]*"' | head -1 | cut -d'"' -f4)
        log error "Failed to create repo: $msg"
        return 1
    fi
}

# ========================
# FILE OPERATIONS (Direct API - NO CLONING!)
# ========================

upload_file() {
    local repo="$1"
    local file_path="$2"
    local repo_path="${3:-$(basename "$file_path")}"
    local commit_msg="${4:-Upload $repo_path}"
    
    # Check if file exists
    if [[ ! -f "$file_path" ]]; then
        log error "File not found: $file_path"
        return 1
    fi
    
    # Check file size
    local file_size
    file_size=$(stat -c%s "$file_path" 2>/dev/null || stat -f%z "$file_path" 2>/dev/null)
    
    if [[ $file_size -gt $MAX_FILE_SIZE ]]; then
        log error "File too large: $file_size bytes (max: $MAX_FILE_SIZE bytes / 100MB)"
        return 1
    fi
    
    # Encode file to base64
    local content
    content=$(base64 -w 0 "$file_path" 2>/dev/null || base64 "$file_path")
    
    # Check if file exists in repo to get SHA using jq
    local sha=""
    local existing_sha
    existing_sha=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$repo/contents/$repo_path" | \
        jq -r '.sha // empty')
    
    if [[ -n "$existing_sha" && "$existing_sha" != "null" ]]; then
        sha="$existing_sha"
        log info "File exists, updating..."
    fi
    
    # Create JSON payload
    local json
    json=$(printf '{"message":"%s","content":"%s"%s}' \
        "$commit_msg" \
        "$content" \
        "$([[ -n "$sha" ]] && printf ',"sha":"%s"' "$sha" || printf '')")
    
    # Upload file directly via API (use temp file for Termux)
    local tmpfile
    tmpfile=$(mktemp)
    printf '%s' "$json" > "$tmpfile"
    
    local api_url="https://api.github.com/repos/$repo/contents/$repo_path"
    if [[ -n "$TARGET_BRANCH" ]]; then
        api_url="$api_url?ref=$TARGET_BRANCH"
    fi
    
    local response code
    response=$(curl -s -w "\n%{http_code}" -X PUT \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        -H "Content-Type: application/json" \
        --data-binary "@$tmpfile" \
        "$api_url")
    code=$(echo "$response" | tail -n1)
    rm -f "$tmpfile"
    
    if [[ "$code" == "200" ]] || [[ "$code" == "201" ]]; then
        log success "Uploaded: $repo_path"
        return 0
    else
        local msg
        msg=$(jq_safe "$response" ".message")
        [[ -z "$msg" ]] && msg="Unknown error"
        log error "Failed: $msg"
        return 1
    fi
}

delete_file() {
    local repo="$1"
    local repo_path="$2"
    local commit_msg="${3:-Delete $repo_path}"
    
    # Get file SHA
    local sha_response
    sha_response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$repo/contents/$repo_path")
    local sha
    sha=$(jq_safe "$sha_response" ".sha")
    
    if [[ -z "$sha" || "$sha" == "null" ]]; then
        log error "File not found: $repo_path"
        return 1
    fi
    
    # Delete via API (use temp file for Termux)
    local tmpfile
    tmpfile=$(mktemp)
    printf '{"message":"%s","sha":"%s"}' "$commit_msg" "$sha" > "$tmpfile"
    
    local response code
    response=$(curl -s -w "\n%{http_code}" -X DELETE \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        -H "Content-Type: application/json" \
        --data-binary "@$tmpfile" \
        "https://api.github.com/repos/$repo/contents/$repo_path")
    code=$(echo "$response" | tail -n1)
    rm -f "$tmpfile"
    
    if [[ "$code" == "200" ]] || [[ "$code" == "204" ]]; then
        log success "Deleted: $repo_path"
        return 0
    else
        local msg
        msg=$(jq_safe "$response" ".message")
        [[ -z "$msg" ]] && msg="Unknown error"
        log error "Failed: $msg (HTTP $code)"
        return 1
    fi
}

list_files() {
    local repo="$1"
    local path="${2:-}"
    
    local url="https://api.github.com/repos/$repo/contents"
    [[ -n "$path" ]] && url="$url/$path"
    
    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "$url")
    
    if echo "$response" | grep -q '"message"'; then
        log error "Failed to list files"
        return 1
    fi
    
    echo -e "${BOLD}Files in $repo${NC}:"
    # Parse response - try jq first, then sed
    if command -v jq > /dev/null 2>&1; then
        echo "$response" | jq -r 'if type == "array" then .[] else . end | .name' 2>/dev/null || echo "$response" | sed -n 's/.*"name": "\([^"]*\)".*/\1/p'
    else
        echo "$response" | sed -n 's/.*"name": "\([^"]*\)".*/\1/p'
    fi
}

# ========================
# MAIN LOGIC
# ========================

resolve_account() {
    local repo_input="$1"
    
    # Check if account specified
    if [[ -n "$SPECIFIED_ACCOUNT" ]]; then
        if ! load_account "$SPECIFIED_ACCOUNT"; then
            log error "Account '$SPECIFIED_ACCOUNT' not found."
            exit 1
        fi
        return 0
    fi
    
    # Try to find account with access
    local accounts=()
    [[ -f "$DEFAULT_CONFIG" ]] && accounts+=("default")
    [[ -d "$ACCOUNTS_DIR" ]] && for cfg in "$ACCOUNTS_DIR"/*/config; do
        [[ -f "$cfg" ]] && accounts+=("$(basename "$(dirname "$cfg")")")
    done
    
    if [[ ${#accounts[@]} -eq 0 ]]; then
        log error "No accounts configured. Run with -A to add one."
        exit 1
    fi
    
    # Try each account
    for acc in "${accounts[@]}"; do
        if load_account "$acc" 2>/dev/null; then
            if verify_account > /dev/null 2>&1; then
                if [[ "$acc" != "default" ]] || [[ -n "$SPECIFIED_ACCOUNT" ]]; then
                    log info "Using account: $acc"
                fi
                return 0
            fi
        fi
    done
    
    log error "No valid account found."
    exit 1
}

do_upload() {
    # Validate inputs
    [[ -z "$REPO" ]] && { log error "Repository required. Use -r repo"; exit 1; }
    [[ ${#FILES[@]} -eq 0 ]] && { log error "No files specified."; exit 1; }
    
    # Only resolve account if not already loaded (interactive mode sets GITHUB_TOKEN)
    if [[ -z "${GITHUB_TOKEN:-}" ]]; then
        resolve_account "$REPO"
    fi
    
    # Expand repo if needed
    if [[ "$REPO" != */* ]]; then
        REPO="$GITHUB_USERNAME/$REPO"
    fi
    
    # Check/create repo
    local code
    code=$(check_repo "$REPO")
    
    if [[ "$code" == "404" ]]; then
        if [[ "$CREATE_REPO" == "true" ]]; then
            local owner="${REPO%%/*}"
            local name="${REPO##*/}"
            create_repo "$owner" "$name" "$IS_PRIVATE" "$REPO_DESCRIPTION"
        else
            log error "Repository not found: $REPO"
            echo "Use -c to create it"
            exit 1
        fi
    elif [[ "$code" != "200" ]]; then
        log error "Cannot access repository: $REPO (HTTP $code)"
        exit 1
    fi
    
    # Upload files
    local success=0
    local failed=0
    local total=${#FILES[@]}
    local current=0
    
    for file in "${FILES[@]}"; do
        current=$((current + 1))
        if [[ -f "$file" ]]; then
            if [[ "$QUIET" != "true" && "$PROGRESS" != "true" ]]; then
                echo -e "${CYAN}${ARROW}${NC} Upload: ${PURPLE}$(basename "$file")${NC}"
            fi
            
            if [[ "$PROGRESS" == "true" ]]; then
                show_progress "$current" "$total" "$file"
            fi
            
            if [[ "$DRY_RUN" == "true" ]]; then
                log info "Would upload: $file"
            else
                if upload_file "$REPO" "$file" "$FILE_PATH" "$COMMIT_MSG"; then
                    success=$((success + 1))
                else
                    failed=$((failed + 1))
                fi
            fi
        else
            log warn "File not found: $file"
            failed=$((failed + 1))
        fi
    done
    
    [[ "$PROGRESS" == "true" ]] && echo
    
    # Summary
    echo
    if [[ "$DRY_RUN" != "true" ]]; then
        [[ $success -gt 0 ]] && log success "Uploaded $success file(s)"
        [[ $failed -gt 0 ]] && log warn "Failed: $failed file(s)"
        
        [[ $success -gt 0 ]] && echo -e "${GREEN}View at: https://github.com/$REPO${NC}"
    fi
    
    [[ $failed -gt 0 ]] && exit 1
}

do_delete() {
    [[ -z "$REPO" ]] && { log error "Repository required. Use -r repo"; exit 1; }
    [[ -z "$DELETE_FILE" ]] && { log error "File to delete required. Use --delete path/to/file"; exit 1; }
    
    if [[ -z "${GITHUB_TOKEN:-}" ]]; then
        resolve_account "$REPO"
    fi
    
    if [[ "$REPO" != */* ]]; then
        REPO="$GITHUB_USERNAME/$REPO"
    fi
    
    delete_file "$REPO" "$DELETE_FILE" "$COMMIT_MSG"
}

do_list() {
    [[ -z "$REPO" ]] && { log error "Repository required. Use -r repo"; exit 1; }
    
    # Only load default if not already set (interactive mode sets it)
    if [[ -z "${GITHUB_TOKEN:-}" ]]; then
        if [[ -f "$DEFAULT_CONFIG" ]]; then
            source "$DEFAULT_CONFIG"
        else
            log error "No account configured. Run -A to add one."
            exit 1
        fi
    fi
    
    # Expand repo if needed
    if [[ "$REPO" != */* ]]; then
        REPO="$GITHUB_USERNAME/$REPO"
    fi
    
    # Get files
    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$REPO/contents")
    
    if echo "$response" | grep -q '"message"'; then
        log error "Failed to list files"
        exit 1
    fi
    
    echo -e "${BOLD}Files in $REPO${NC}:"
    echo "$response" | jq -r '.[].name' 2>/dev/null || echo "$response" | sed -n 's/.*"name": "\([^"]*\)".*/\1/p'
}

# Helper function to show account selection menu
select_account() {
    echo -e "${BOLD}Available accounts:${NC}"
    
    local accounts=()
    local count=1
    local default_user=""
    
    # Get default username first
    if [[ -f "$DEFAULT_CONFIG" ]]; then
        default_user=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" 2>/dev/null | cut -d= -f2- | tr -d '"')
    fi
    
    # Add default account
    if [[ -n "$default_user" ]]; then
        echo -e "  ${CYAN}$count)${NC} default: $default_user"
        accounts+=("default|$default_user")
        count=$((count + 1))
    fi
    
    # Add additional accounts, skip if same as default
    if [[ -d "$ACCOUNTS_DIR" ]]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [[ -f "$cfg" ]] || continue
            local acc
            acc=$(basename "$(dirname "$cfg")")
            local u
            u=$(grep '^GITHUB_USERNAME=' "$cfg" 2>/dev/null | cut -d= -f2- | tr -d '"')
            # Skip if same as default user
            [[ "$u" == "$default_user" ]] && continue
            [[ -z "$u" ]] && u="(no username)"
            echo -e "  ${CYAN}$count)${NC} $acc: $u"
            accounts+=("$acc|$u")
            count=$((count + 1))
        done
    fi
    
    if [[ ${#accounts[@]} -eq 0 ]]; then
        echo "  (no accounts configured)"
        return 1
    fi
    
    echo
    read -rp "Select account [1-${#accounts[@]}]: " choice
    
    if [[ -z "$choice" ]] || [[ "$choice" -lt 1 ]] || [[ "$choice" -gt ${#accounts[@]} ]]; then
        log error "Invalid selection"
        return 1
    fi
    
    local selected="${accounts[$((choice - 1))]}"
    local acc_name="${selected%|*}"
    local acc_user="${selected##*|}"
    
    # Load the account config
    if [[ "$acc_name" == "default" ]]; then
        . "$DEFAULT_CONFIG"
    else
        . "$ACCOUNTS_DIR/$acc_name/config"
    fi
    
    # If username is empty, get it from the config file directly
    if [[ -z "${GITHUB_USERNAME:-}" ]]; then
        if [[ "$acc_name" == "default" ]]; then
            GITHUB_USERNAME=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" 2>/dev/null | cut -d= -f2- | tr -d '"')
        else
            GITHUB_USERNAME=$(grep '^GITHUB_USERNAME=' "$ACCOUNTS_DIR/$acc_name/config" 2>/dev/null | cut -d= -f2- | tr -d '"')
        fi
    fi
    
    # If still empty, show error
    if [[ -z "${GITHUB_USERNAME:-}" ]]; then
        log error "Account '$acc_name' has no username. Please remove and re-add this account with correct username."
        return 1
    fi
    
    # Validate the account by checking if token works
    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" "https://api.github.com/user" 2>/dev/null)
    if echo "$response" | grep -q '"login"'; then
        return 0
    else
        log error "Account credentials are invalid. Please remove and re-add this account with correct token."
        return 1
    fi
}

