#!/usr/bin/env bash
################################################################################
# GitHub File Upload Tool
# Upload any files to a GitHub repository from Termux/Unix using gh CLI.
# Supports: txt, pdf, apk, images, archives, any file type.
#
# Usage:
#   github-upload [options] [file1 file2 ...]
#
# Options:
#   -r, --repo REPO        Repository name (user/repo or just repo)
#   -m, --message MSG      Commit message (default: "Upload files via github-upload")
#   -b, --branch BRANCH    Target branch (default: main)
#   -c, --create           Create repository if it doesn't exist
#   -d, --description DESC Repository description when creating
#   --public              Make new repo public (default: public)
#   --private             Make new repo private
#   -h, --help            Show this help message
#
# Configuration:
#   First run will prompt for GitHub credentials and save them to
#   ~/.config/github-upload/config for reuse.
#
# Examples:
#   github-upload file.txt
#   github-upload -r myuser/myrepo file1.pdf file2.apk
#   github-upload -m "Backup from Termux" /sdcard/*
################################################################################

set -euo pipefail

# Configuration
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/github-upload"
CONFIG_FILE="$CONFIG_DIR/config"
STATE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/github-upload"
STATE_FILE="$STATE_DIR/state"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Defaults
REPO=""
COMMIT_MSG="Upload files via github-upload"
BRANCH="${GITHUB_DEFAULT_BRANCH:-main}"
CREATE_REPO=false
REPO_DESCRIPTION=""
VISIBILITY="--public"
FILES=()
INTERACTIVE=false
HELP=false

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        -r|--repo)
            REPO="$2"
            shift 2
            ;;
        -m|--message)
            COMMIT_MSG="$2"
            shift 2
            ;;
        -b|--branch)
            BRANCH="$2"
            shift 2
            ;;
        -c|--create)
            CREATE_REPO=true
            shift
            ;;
        -d|--description)
            REPO_DESCRIPTION="$2"
            shift 2
            ;;
        --public)
            VISIBILITY="--public"
            shift
            ;;
        --private)
            VISIBILITY="--private"
            shift
            ;;
        -h|--help)
            HELP=true
            shift
            ;;
        -*)
            echo -e "${RED}Error: Unknown option $1${NC}" >&2
            exit 1
            ;;
        *)
            FILES+=("$1")
            shift
            ;;
    esac
done

if $HELP; then
    grep '^#' "$0" | sed -n '2,38p' | cut -c4-
    exit 0
fi

# Check dependencies
if ! command -v gh &>/dev/null; then
    echo -e "${RED}Error: GitHub CLI (gh) not installed.${NC}" >&2
    echo "Install in Termux with: pkg install gh" >&2
    exit 1
fi

if ! command -v git &>/dev/null; then
    echo -e "${RED}Error: git not installed.${NC}" >&2
    echo "Install in Termux with: pkg install git" >&2
    exit 1
fi

# Load or prompt for credentials
load_credentials() {
    if [ -f "$CONFIG_FILE" ]; then
        # shellcheck disable=SC1090
        source "$CONFIG_FILE" >/dev/null 2>&1
        return 0
    fi
    return 1
}

save_credentials() {
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" <<EOF
# GitHub Upload credentials - DO NOT SHARE
GITHUB_USERNAME="$GITHUB_USERNAME"
GITHUB_TOKEN="$GITHUB_TOKEN"
EOF
    chmod 600 "$CONFIG_FILE"
}

prompt_credentials() {
    echo -e "${BLUE}GitHub Authentication${NC}"
    read -rp "GitHub username: " GITHUB_USERNAME
    read -rsp "GitHub Personal Access Token (ghp_...): " GITHUB_TOKEN
    echo
    save_credentials
    echo -e "${GREEN}Credentials saved to $CONFIG_FILE${NC}"
}

# Ensure authenticated
if ! load_credentials; then
    prompt_credentials
fi

# Authenticate gh (only needed if not already authenticated)
if ! gh auth status &>/dev/null; then
    echo -e "${BLUE}Authenticating with GitHub...${NC}"
    echo "$GITHUB_TOKEN" | gh auth login --with-token >/dev/null
fi

# Normalize repo name
normalize_repo() {
    local r="$1"
    # If it's just "repo", prepend username
    if [[ "$r" != */* ]]; then
        r="$GITHUB_USERNAME/$r"
    fi
    echo "$r"
}

# Check/create repository
ensure_repository() {
    local repo="$1"
    local create="$2"
    local desc="$3"
    local vis="$4"

    if gh repo view "$repo" &>/dev/null; then
        echo -e "${GREEN}✓ Repository exists: $repo${NC}"
        return 0
    fi

    if $create; then
        echo -e "${YELLOW}Creating repository: $repo${NC}"
        gh repo create "$repo" \
            --description "${desc:-Uploaded via github-upload}" \
            $vis \
            --source "$tmpdir" \
            --remote "$repo" \
            --push >/dev/null
        echo -e "${GREEN}✓ Repository created${NC}"
        return 0
    fi

    echo -e "${RED}Error: Repository '$repo' not found.${NC}" >&2
    echo "Use -c/--create to create it automatically." >&2
    exit 1
}

# Gather file list if not provided
gather_files() {
    if [ ${#FILES[@]} -gt 0 ]; then
        # Validate files exist
        local missing=0
        for f in "${FILES[@]}"; do
            if [ ! -e "$f" ]; then
                echo -e "${YELLOW}Warning: '$f' not found, skipping${NC}" >&2
                missing=1
            fi
        done
        if [ $missing -eq 1 ] && [ ${#FILES[@]} -eq 1 ]; then
            exit 1
        fi
        return 0
    fi

    # Interactive mode
    echo "Enter file paths (one per line, empty line to finish):"
    while IFS= read -r line; do
        [ -z "$line" ] && break
        FILES+=("$line")
    done

    if [ ${#FILES[@]} -eq 0 ]; then
        echo -e "${RED}Error: No files specified.${NC}" >&2
        exit 1
    fi
}

# Main
if $HELP; then exit 0; fi

if [ -z "$REPO" ]; then
    echo -e "${BLUE}Repository${NC}"
    read -rp "Repository name (e.g., my-repo or user/repo): " REPO_INPUT
    REPO="$REPO_INPUT"
    if [ -z "$REPO" ]; then
        echo -e "${RED}Error: Repository name required.${NC}" >&2
        exit 1
    fi
fi

REPO="$(normalize_repo "$REPO")"

gather_files

# Filter only existing files
VALID_FILES=()
for f in "${FILES[@]}"; do
    if [ -e "$f" ]; then
        VALID_FILES+=("$f")
    else
        echo -e "${YELLOW}Warning: '$f' does not exist, skipping${NC}" >&2
    fi
done

if [ ${#VALID_FILES[@]} -eq 0 ]; then
    echo -e "${RED}Error: No valid files to upload.${NC}" >&2
    exit 1
fi

# Temporary workspace
tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

# Prepare repository
ensure_repository "$REPO" "$CREATE_REPO" "$REPO_DESCRIPTION" "$VISIBILITY"

# Clone
echo -e "${BLUE}Cloning repository...${NC}"
if ! gh repo clone "$REPO" "$tmpdir" -- --branch "$BRANCH" 2>/dev/null; then
    # Try default branch
    gh repo clone "$REPO" "$tmpdir"
fi

# Copy files
echo -e "${BLUE}Copying files...${NC}"
for f in "${VALID_FILES[@]}"; do
    cp -r "$f" "$tmpdir/"
    echo "  + $(basename "$f")"
done

# Commit and push
(
    cd "$tmpdir"
    git add --all
    if ! git diff --cached --quiet; then
        echo -e "${BLUE}Committing and pushing...${NC}"
        git commit -m "$COMMIT_MSG"
        git push origin "$BRANCH"
    else
        echo -e "${YELLOW}No changes to commit (files unchanged).${NC}"
    fi
)

echo -e "${GREEN}✓ Upload complete${NC}"
echo "View at: https://github.com/$REPO"
