#!/usr/bin/env bash
################################################################################
# GitHub Direct Upload Tool
#
# Upload files directly to GitHub via API (NO CLONING NEEDED!)
# Features: No clone, 100MB support, quiet mode, fixed help, delete files
################################################################################

set -euo pipefail

# ========================
# CONFIGURATION
# ========================

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/github-upload"
DEFAULT_CONFIG="$CONFIG_DIR/config"
ACCOUNTS_DIR="$CONFIG_DIR/accounts"
MAX_FILE_SIZE=104857600  # 100MB in bytes

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ========================
# HELPER FUNCTIONS
# ========================

log() {
    local type="$1"
    shift
    local msg="$*"
    
    case "$type" in
        info)    [[ "$QUIET" != "true" ]] && echo -e "${BLUE}[INFO]${NC} $msg" ;;
        success) [[ "$QUIET" != "true" ]] && echo -e "${GREEN}[OK]${NC} $msg" ;;
        warn)    [[ "$QUIET" != "true" ]] && echo -e "${YELLOW}[WARN]${NC} $msg" ;;
        error)   echo -e "${RED}[ERROR]${NC} $msg" >&2 ;;
        quiet)   : ;;  # Silent
    esac
}

# ========================
# ACCOUNT MANAGEMENT
# ========================

add_account() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        read -rp "Account name (e.g., personal, work): " name
        [[ -n "$name" ]] || { echo "Account name required"; exit 1; }
    fi
    
    local config_dir="$ACCOUNTS_DIR/$name"
    local config_file="$config_dir/config"
    
    if [[ -e "$config_file" && "${OVERWRITE:-}" != "true" ]]; then
        read -rp "Account '$name' exists. Overwrite? (y/N): " overwrite
        [[ "$overwrite" =~ ^[Yy]$ ]] || { echo "Aborted."; return; }
    fi
    
    echo -e "${CYAN}Adding account: $name${NC}"
    read -rp "GitHub username: " user
    read -rsp "GitHub Personal Access Token: " token
    echo
    
    mkdir -p "$config_dir"
    cat > "$config_file" <<EOF
GITHUB_USERNAME="$user"
GITHUB_TOKEN="$token"
EOF
    chmod 600 "$config_file"
    echo -e "${GREEN}✓ Account '$name' saved.${NC}"
}

list_accounts() {
    echo "Configured accounts:"
    local count=0
    
    if [[ -f "$DEFAULT_CONFIG" ]]; then
        local user
        user=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" | cut -d= -f2- | tr -d '"' || echo "unknown")
        echo -e "  ${BLUE}default${NC}: $user"
        count=$((count + 1))
    fi
    
    if [[ -d "$ACCOUNTS_DIR" ]]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [[ -f "$cfg" ]] || continue
            local acc
            acc=$(basename "$(dirname "$cfg")")
            local u
            u=$(grep '^GITHUB_USERNAME=' "$cfg" | cut -d= -f2- | tr -d '"' || echo "unknown")
            echo -e "  ${BLUE}$acc${NC}: $u"
            count=$((count + 1))
        done
    fi
    
    [[ $count -eq 0 ]] && echo "  (none configured)"
    echo
}

load_account() {
    local name="$1"
    unset GITHUB_USERNAME GITHUB_TOKEN 2>/dev/null
    
    if [[ -z "$name" ]] || [[ "$name" == "default" ]]; then
        if [[ -f "$DEFAULT_CONFIG" ]]; then
            # shellcheck disable=SC1090
            source "$DEFAULT_CONFIG"
        fi
        [[ -n "${GITHUB_USERNAME:-}" && -n "${GITHUB_TOKEN:-}" ]] && return 0
        return 1
    else
        local cfg="$ACCOUNTS_DIR/$name/config"
        if [[ -f "$cfg" ]]; then
            # shellcheck disable=SC1090
            source "$cfg"
        fi
        [[ -n "${GITHUB_USERNAME:-}" && -n "${GITHUB_TOKEN:-}" ]] && return 0
        return 1
    fi
}

verify_account() {
    local response
    response=$(curl -s -w "\n%{http_code}" -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/user")
    local code
    code=$(echo "$response" | tail -n1)
    
    if [[ "$code" == "200" ]]; then
        local username
        username=$(echo "$response" | grep -o '"login":"[^"]*"' | head -1 | cut -d'"' -f4)
        echo "$username"
        return 0
    fi
    return 1
}

# ========================
# REPO OPERATIONS
# ========================

check_repo() {
    local repo="$1"
    local response
    response=$(curl -s -w "\n%{http_code}" -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$repo")
    local code
    code=$(echo "$response" | tail -n1)
    echo "$code"
}

create_repo() {
    local repo_owner="$1"
    local repo_name="$2"
    local is_private="${3:-false}"
    local description="${4:-}"
    
    local json
    if [[ -n "$description" ]]; then
        json="{\"name\":\"$repo_name\",\"description\":\"$description\",\"private\":$is_private}"
    else
        json="{\"name\":\"$repo_name\",\"private\":$is_private}"
    fi
    
    local api_url
    if [[ "$repo_owner" == "$GITHUB_USERNAME" ]]; then
        api_url="https://api.github.com/user/repos"
    else
        api_url="https://api.github.com/orgs/$repo_owner/repos"
    fi
    
    local response code
    response=$(curl -s -w "\n%{http_code}" -X POST \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        -d "$json" \
        "$api_url")
    code=$(echo "$response" | tail -n1)
    
    if [[ "$code" == "201" ]] || [[ "$code" == "200" ]]; then
        log success "Repository created"
        return 0
    else
        local msg
        msg=$(echo "$response" | grep -o '"message":"[^"]*"' | head -1 | cut -d'"' -f4)
        log error "Failed to create repo: $msg"
        return 1
    fi
}

# ========================
# FILE OPERATIONS (Direct API - NO CLONING!)
# ========================

upload_file() {
    local repo="$1"
    local file_path="$2"
    local repo_path="${3:-$(basename "$file_path")}"
    local commit_msg="${4:-Upload $repo_path}"
    
    # Check if file exists
    if [[ ! -f "$file_path" ]]; then
        log error "File not found: $file_path"
        return 1
    fi
    
    # Check file size
    local file_size
    file_size=$(stat -c%s "$file_path" 2>/dev/null || stat -f%z "$file_path" 2>/dev/null)
    
    if [[ $file_size -gt $MAX_FILE_SIZE ]]; then
        log error "File too large: $file_size bytes (max: $MAX_FILE_SIZE bytes / 100MB)"
        return 1
    fi
    
    # Encode file to base64
    local content
    content=$(base64 -w 0 "$file_path" 2>/dev/null || base64 "$file_path")
    
    # Check if file exists in repo to get SHA using jq
    local sha=""
    local existing_sha
    existing_sha=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$repo/contents/$repo_path" | \
        jq -r '.sha // empty')
    
    if [[ -n "$existing_sha" && "$existing_sha" != "null" ]]; then
        sha="$existing_sha"
        log info "File exists, updating..."
    fi
    
    # Create JSON payload
    local json
    json=$(printf '{"message":"%s","content":"%s"%s}' \
        "$commit_msg" \
        "$content" \
        "$([[ -n "$sha" ]] && printf ',"sha":"%s"' "$sha" || printf '')")
    
    # Upload file directly via API (use temp file for Termux compatibility)
    local tmpfile
    tmpfile=$(mktemp)
    printf '%s' "$json" > "$tmpfile"
    
    local response code
    response=$(curl -s -w "\n%{http_code}" -X PUT \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        -H "Content-Type: application/json" \
        --data-binary "@$tmpfile" \
        "https://api.github.com/repos/$repo/contents/$repo_path")
    code=$(echo "$response" | tail -n1)
    rm -f "$tmpfile"
    
    if [[ "$code" == "200" ]] || [[ "$code" == "201" ]]; then
        log success "Uploaded: $repo_path"
        return 0
    else
        local msg
        if command -v jq > /dev/null 2>&1; then
            msg=$(echo "$response" | jq -r '.message // "Unknown error"')
        else
            msg=$(echo "$response" | grep -o '"message":"[^"]*"' | head -1 | cut -d'"' -f4 || echo "Unknown error")
        fi
        log error "Failed: $msg"
        return 1
    fi
}

delete_file() {
    local repo="$1"
    local repo_path="$2"
    local commit_msg="${3:-Delete $repo_path}"
    
    # Get file SHA using jq
    local sha
    sha=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$repo/contents/$repo_path" | \
        jq -r '.sha // empty')
    
    if [[ -z "$sha" || "$sha" == "null" ]]; then
        log error "File not found: $repo_path"
        return 1
    fi
    
    # Delete via API (use temp file for Termux compatibility)
    local tmpfile
    tmpfile=$(mktemp)
    printf '{"message":"%s","sha":"%s"}' "$commit_msg" "$sha" > "$tmpfile"
    
    local response code
    response=$(curl -s -w "\n%{http_code}" -X DELETE \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        -H "Content-Type: application/json" \
        --data-binary "@$tmpfile" \
        "https://api.github.com/repos/$repo/contents/$repo_path")
    code=$(echo "$response" | tail -n1)
    rm -f "$tmpfile"
    
    if [[ "$code" == "200" ]] || [[ "$code" == "204" ]]; then
        log success "Deleted: $repo_path"
        return 0
    else
        local msg
        if command -v jq > /dev/null 2>&1; then
            msg=$(echo "$response" | jq -r '.message // "Unknown error"')
        else
            msg=$(echo "$response" | grep -o '"message":"[^"]*"' | head -1 | cut -d'"' -f4 || echo "Unknown error")
        fi
        log error "Failed: $msg (HTTP $code)"
        return 1
    fi
}

list_files() {
    local repo="$1"
    local path="${2:-}"
    
    local url="https://api.github.com/repos/$repo/contents"
    [[ -n "$path" ]] && url="$url/$path"
    
    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "$url")
    
    if echo "$response" | grep -q '"message"'; then
        log error "Failed to list files"
        return 1
    fi
    
    echo -e "${BOLD}Files in $repo${NC}:"
    # Parse response - try jq first, then sed
    if command -v jq > /dev/null 2>&1; then
        echo "$response" | jq -r 'if type == "array" then .[] else . end | .name' 2>/dev/null || echo "$response" | sed -n 's/.*"name": "\([^"]*\)".*/\1/p'
    else
        echo "$response" | sed -n 's/.*"name": "\([^"]*\)".*/\1/p'
    fi
}

# ========================
# MAIN LOGIC
# ========================

resolve_account() {
    local repo_input="$1"
    
    # Check if account specified
    if [[ -n "$SPECIFIED_ACCOUNT" ]]; then
        if ! load_account "$SPECIFIED_ACCOUNT"; then
            log error "Account '$SPECIFIED_ACCOUNT' not found."
            exit 1
        fi
        return 0
    fi
    
    # Try to find account with access
    local accounts=()
    [[ -f "$DEFAULT_CONFIG" ]] && accounts+=("default")
    [[ -d "$ACCOUNTS_DIR" ]] && for cfg in "$ACCOUNTS_DIR"/*/config; do
        [[ -f "$cfg" ]] && accounts+=("$(basename "$(dirname "$cfg")")")
    done
    
    if [[ ${#accounts[@]} -eq 0 ]]; then
        log error "No accounts configured. Run with -A to add one."
        exit 1
    fi
    
    # Try each account
    for acc in "${accounts[@]}"; do
        if load_account "$acc" 2>/dev/null; then
            if verify_account > /dev/null 2>&1; then
                if [[ "$acc" != "default" ]] || [[ -n "$SPECIFIED_ACCOUNT" ]]; then
                    log info "Using account: $acc"
                fi
                return 0
            fi
        fi
    done
    
    log error "No valid account found."
    exit 1
}

do_upload() {
    # Validate inputs
    [[ -z "$REPO" ]] && { log error "Repository required. Use -r repo"; exit 1; }
    [[ ${#FILES[@]} -eq 0 ]] && { log error "No files specified."; exit 1; }
    
    # Resolve account
    resolve_account "$REPO"
    
    # Expand repo if needed
    if [[ "$REPO" != */* ]]; then
        REPO="$GITHUB_USERNAME/$REPO"
    fi
    
    # Check/create repo
    local code
    code=$(check_repo "$REPO")
    
    if [[ "$code" == "404" ]]; then
        if [[ "$CREATE_REPO" == "true" ]]; then
            local owner="${REPO%%/*}"
            local name="${REPO##*/}"
            create_repo "$owner" "$name" "$IS_PRIVATE" "$REPO_DESCRIPTION"
        else
            log error "Repository not found: $REPO"
            echo "Use -c to create it"
            exit 1
        fi
    elif [[ "$code" != "200" ]]; then
        log error "Cannot access repository: $REPO (HTTP $code)"
        exit 1
    fi
    
    # Upload files
    local success=0
    local failed=0
    
    for file in "${FILES[@]}"; do
        if [[ -f "$file" ]]; then
            if [[ "$QUIET" != "true" ]]; then
                echo -e "${BLUE}Uploading:${NC} $file"
            fi
            
            if [[ "$DRY_RUN" == "true" ]]; then
                log info "Would upload: $file"
            else
                if upload_file "$REPO" "$file" "$FILE_PATH" "$COMMIT_MSG"; then
                    success=$((success + 1))
                else
                    failed=$((failed + 1))
                fi
            fi
        else
            log warn "File not found: $file"
            failed=$((failed + 1))
        fi
    done
    
    # Summary
    echo
    if [[ "$DRY_RUN" != "true" ]]; then
        [[ $success -gt 0 ]] && log success "Uploaded $success file(s)"
        [[ $failed -gt 0 ]] && log warn "Failed: $failed file(s)"
        
        [[ $success -gt 0 ]] && echo -e "${GREEN}View at: https://github.com/$REPO${NC}"
    fi
    
    [[ $failed -gt 0 ]] && exit 1
}

do_delete() {
    [[ -z "$REPO" ]] && { log error "Repository required. Use -r repo"; exit 1; }
    [[ -z "$DELETE_FILE" ]] && { log error "File to delete required. Use --delete path/to/file"; exit 1; }
    
    resolve_account "$REPO"
    
    if [[ "$REPO" != */* ]]; then
        REPO="$GITHUB_USERNAME/$REPO"
    fi
    
    delete_file "$REPO" "$DELETE_FILE" "$COMMIT_MSG"
}

do_list() {
    [[ -z "$REPO" ]] && { log error "Repository required. Use -r repo"; exit 1; }
    
    # Load default account directly
    if [[ -f "$DEFAULT_CONFIG" ]]; then
        source "$DEFAULT_CONFIG"
    else
        log error "No account configured. Run -A to add one."
        exit 1
    fi
    
    # Expand repo if needed
    if [[ "$REPO" != */* ]]; then
        REPO="$GITHUB_USERNAME/$REPO"
    fi
    
    # Get files
    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$REPO/contents")
    
    if echo "$response" | grep -q '"message"'; then
        log error "Failed to list files"
        exit 1
    fi
    
    echo -e "${BOLD}Files in $REPO${NC}:"
    echo "$response" | jq -r '.[].name' 2>/dev/null || echo "$response" | sed -n 's/.*"name": "\([^"]*\)".*/\1/p'
}

list_repos() {
    if [[ -f "$DEFAULT_CONFIG" ]]; then
        source "$DEFAULT_CONFIG"
    else
        log error "No account configured. Run -A to add one."
        exit 1
    fi
    
    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/user/repos?per_page=100")
    
    if echo "$response" | grep -q '"message"'; then
        log error "Failed to list repos"
        exit 1
    fi
    
    echo -e "${BOLD}Your repositories:${NC}"
    if command -v jq > /dev/null 2>&1; then
        echo "$response" | jq -r '.[] | "\(.name) (\(.private ? "private" : "public"))"' 2>/dev/null || \
        echo "$response" | jq -r '.[].name'
    else
        echo "$response" | sed -n 's/.*"name": "\([^"]*\)".*/\1/p'
    fi
}

show_help() {
    cat << 'HELPEOF'
╔══════════════════════════════════════════════════════════════════╗
║              GitHub Direct Upload Tool v2.0                      ║
║          Upload files to GitHub WITHOUT cloning!                 ║
╚══════════════════════════════════════════════════════════════════╝

USAGE:
    github-upload [options] -r REPO FILE...

OPTIONS:
    -r, --repo REPO           Repository (user/repo or just repo)
    -c, --create              Create repository if it doesn't exist
    -p, --private             Make new repository private
    -d, --description TEXT   Repository description (with -c)
    -m, --message TEXT        Commit message (default: "Upload filename")
    -f, --file-path PATH      Upload file to this path in repo
        
    -A, --add-account [NAME] Add a GitHub account
    -a, --account NAME       Use specific account
    --list-accounts          Show saved accounts
        
--delete PATH            Delete a file from repository
        --list [PATH]            List files in repository
        --list-repos            List your repositories
        
    -q, --quiet              Quiet mode (minimal output)
    -n, --dry-run            Show what would be uploaded
    -h, --help               Show this help
        
    --clear                  Clear saved credentials

EXAMPLES:
    # Upload a file
    github-upload -r my-repo -c app.apk
    
    # Upload with custom message
    github-upload -r my-repo -m "Version 2.0" app.apk
    
    # Upload to specific path
    github-upload -r my-repo -f "apps/android/app.apk" app.apk
    
    # Upload multiple files
    github-upload -r my-repo app.apk icon.png readme.txt
    
    # Upload with wildcard
    github-upload -r my-repo '*.apk'
    
    # Create private repo and upload
    github-upload -r my-repo -c -p -d "My app" app.apk
    
    # Delete a file
    github-upload -r my-repo --delete old-file.txt
    
    # List files in repo
    github-upload -r my-repo --list
    
    # List your repositories
    github-upload --list-repos
    
    # Add account
    github-upload -A
    
    # Use specific account
    github-upload -a work -r company/repo file.txt

NOTES:
    • Uses GitHub API directly - NO git clone needed!
    • Max file size: 100MB
    • Files upload to repo root by default
    • Use -f to specify upload path
    • Credentials stored in ~/.config/github-upload/

HELPEOF
}

# ========================
# PARSE ARGUMENTS
# ========================

REPO=""
CREATE_REPO="false"
IS_PRIVATE="false"
REPO_DESCRIPTION=""
COMMIT_MSG=""
FILES=()
SPECIFIED_ACCOUNT=""
DELETE_FILE=""
DO_LIST="false"
LIST_REPOS="false"
LIST_PATH=""
FILE_PATH=""
DRY_RUN="false"
QUIET="false"
SHOW_ACCOUNTS="false"
ADD_ACCOUNT=""
CLEAR_CREDS="false"
OVERWRITE="false"

while [[ $# -gt 0 ]]; do
    case "$1" in
        -r|--repo)
            REPO="$2"
            shift 2
            ;;
        -c|--create)
            CREATE_REPO="true"
            shift
            ;;
        -p|--private)
            IS_PRIVATE="true"
            shift
            ;;
        -d|--description)
            REPO_DESCRIPTION="$2"
            shift 2
            ;;
        -m|--message)
            COMMIT_MSG="$2"
            shift 2
            ;;
        -f|--file-path)
            FILE_PATH="$2"
            shift 2
            ;;
        -a|--account)
            SPECIFIED_ACCOUNT="$2"
            shift 2
            ;;
        -A|--add-account)
            ADD_ACCOUNT="${2:-}"
            [[ "$ADD_ACCOUNT" != -* ]] && shift || ADD_ACCOUNT=""
            shift
            ;;
        --list-accounts)
            SHOW_ACCOUNTS="true"
            shift
            ;;
        --delete)
            DELETE_FILE="$2"
            shift 2
            ;;
        --list)
            DO_LIST="true"
            if [[ $# -gt 1 && "$2" != -* ]]; then
                LIST_PATH="$2"
                shift
            fi
            shift
            ;;
        --list-repos)
            LIST_REPOS="true"
            shift
            ;;
        -q|--quiet)
            QUIET="true"
            shift
            ;;
        -n|--dry-run)
            DRY_RUN="true"
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        --clear)
            CLEAR_CREDS="true"
            shift
            ;;
        --overwrite)
            OVERWRITE="true"
            shift
            ;;
        -*)
            log error "Unknown option: $1"
            exit 1
            ;;
        *)
            FILES+=("$1")
            shift
            ;;
    esac
done

# ========================
# EXECUTE
# ========================

# Check dependencies
for cmd in curl stat; do
    command -v "$cmd" > /dev/null || { log error "Required command '$cmd' not found"; exit 1; }
done

# Handle --clear
if [[ "$CLEAR_CREDS" == "true" ]]; then
    rm -rf "$CONFIG_DIR"
    log success "Credentials cleared"
    exit 0
fi

# Handle --list-accounts
if [[ "$SHOW_ACCOUNTS" == "true" ]]; then
    list_accounts
    exit 0
fi

# Handle --add-account
if [[ -n "$ADD_ACCOUNT" ]]; then
    add_account "$ADD_ACCOUNT"
    exit 0
fi

# Handle --delete
if [[ -n "$DELETE_FILE" ]]; then
    do_delete
    exit $?
fi

# Handle --list
if [[ "$DO_LIST" == "true" ]]; then
    do_list
    exit $?
fi

# Handle --list-repos
if [[ "$LIST_REPOS" == "true" ]]; then
    list_repos
    exit $?
fi

# Handle upload
do_upload
