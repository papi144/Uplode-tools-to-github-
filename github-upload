interactive_upload_dir() {
    select_account || return

    read -rp "Repository (user/repo or just repo name): " repo
    [[ -z "$repo" ]] && { log error "Repository required"; return; }

    read -rp "Directory path to upload: " dir_path
    [[ -z "$dir_path" ]] && { log error "Directory path required"; return; }

    if [[ ! -d "$dir_path" ]]; then
        log error "Directory not found: $dir_path"
        return
    fi

    if [[ -z "${GITHUB_USERNAME:-}" ]]; then
        GITHUB_USERNAME=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" 2>/dev/null | cut -d= -f2- | tr -d '"')
    fi

    [[ "$repo" != */* ]] && repo="$GITHUB_USERNAME/$repo"

    read -rp "Commit message (optional): " commit_msg
    [[ -z "$commit_msg" ]] && commit_msg="Upload $(basename "$dir_path")"

    local code
    code=$(check_repo "$repo")

    if [[ "$code" == "404" ]]; then
        read -rp "Repository not found. Create it? (y/N): " create_it
        if [[ "$create_it" =~ ^[Yy]$ ]]; then
            local owner="${repo%%/*}"
            local name="${repo##*/}"
            create_repo "$owner" "$name" "false" ""
        else
            return
        fi
    elif [[ "$code" != "200" ]]; then
        log error "Cannot access repository: $repo (HTTP $code)"
        return
    fi

    local base_dir
    base_dir=$(basename "$dir_path")
    local success=0
    local failed=0
    local skipped=0

    local ignore_patterns=(
        ".git"
        "node_modules"
        ".DS_Store"
        "Thumbs.db"
        "*.log"
        ".env"
        ".env.local"
        "__pycache__"
        "*.pyc"
        ".gradle"
        "build/"
        "*.apk"
        "*.aab"
    )

    if [[ -f "$dir_path/.github-upload-ignore" ]]; then
        while IFS= read -r pattern; do
            [[ -n "$pattern" && ! "$pattern" =~ ^# ]] && ignore_patterns+=("$pattern")
        done < "$dir_path/.github-upload-ignore"
    fi

    log info "Fetching existing files and sizes..."
    declare -A existing_sizes
    local existing_response
    existing_response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$repo/contents/$base_dir")

    while IFS= read -r line; do
        local name size
        name=$(echo "$line" | sed -n 's/.*"name": *"\([^"]*\)".*/\1/p')
        size=$(echo "$line" | sed -n 's/.*"size": *\([0-9]*\).*/\1/p')
        if [[ -n "$name" && -n "$size" ]]; then
            existing_sizes["$name"]="$size"
        fi
    done < <(echo "$existing_response" | grep -o '{[^}]*}')

    for existing in "${!existing_sizes[@]}"; do
        log info "Found: $existing (${existing_sizes[$existing]} bytes)"
    done

    log info "Checking files in: $dir_path"
    echo -e "${DIM}Ignoring: ${ignore_patterns[*]}${NC}"
    echo
    echo -e "${CYAN}[i]${NC} Resume mode: comparing with existing files..."

    local total_files=0
    while IFS= read -r -d '' f; do
        total_files=$((total_files + 1))
    done < <(find "$dir_path" -type f -print0)
    log info "Total files to check: $total_files"

    local current=0

    local upload_count=0

    while IFS= read -r -d '' file; do
        local rel_path="${file#$dir_path/}"
        local filename=$(basename "$file")
        local skip=false

        for pattern in "${ignore_patterns[@]}"; do
            if [[ "$rel_path" == *"$pattern"* ]] || [[ "$filename" == $pattern ]]; then
                skip=true
                break
            fi
        done

        if [[ "$skip" == "true" ]]; then
            skipped=$((skipped + 1))
            continue
        fi

        local repo_path="$base_dir/$rel_path"
        local upload=true

        local local_size
        local_size=$(stat -c%s "$file" 2>/dev/null) || local_size=$(stat -f%z "$file" 2>/dev/null)

        if [[ -v "existing_sizes[$rel_path]" ]]; then
            local remote_size="${existing_sizes[$rel_path]}"
            if [[ "$local_size" == "$remote_size" ]]; then
                upload=false
            else
                log info "Size changed: $rel_path (local: $local_size, remote: $remote_size) - will update"
                upload=true
            fi
        fi

        if [[ "$upload" == "false" ]]; then
            log info "Skipped (unchanged): $repo_path"
            skipped=$((skipped + 1))
            continue
        fi

        upload_count=$((upload_count + 1))
        current=$((current + 1))

        local file_size
        file_size=$(stat -c%s "$file" 2>/dev/null) || file_size=$(stat -f%z "$file" 2>/dev/null)

        if [[ "$PROGRESS" == "true" ]] || [[ $upload_count -gt 1 ]] || [[ $file_size -gt $LARGE_FILE_SIZE ]]; then
            show_progress "$current" "$upload_count" "$file"
        else
            [[ "$QUIET" != "true" ]] && echo -e "${CYAN}${ARROW}${NC} Upload: ${PURPLE}$repo_path${NC}"
        fi

        if upload_file "$repo" "$file" "$repo_path" "$commit_msg"; then
            success=$((success + 1))
        else
            failed=$((failed + 1))
        fi
    done < <(find "$dir_path" -type f -print0)

    if [[ $upload_count -eq 0 ]]; then
        log info "All files already up to date!"
    fi

    if [[ "$PROGRESS" == "true" ]] || [[ $upload_count -gt 1 ]]; then
        echo
    fi

    echo
    [[ $success -gt 0 ]] && log success "Uploaded $success file(s)"
    [[ $skipped -gt 0 ]] && log warn "Skipped: $skipped file(s)"
    [[ $failed -gt 0 ]] && log error "Failed: $failed file(s)"
    [[ $success -gt 0 ]] && echo -e "${GREEN}View at: https://github.com/$repo${NC}"

    [[ $failed -gt 0 ]] && exit 1
}

show_help() {
    cat << 'HELPEOF'
╔══════════════════════════════════════════════════════════════════╗
║        GitHub Direct Upload Tool v2.14                 ║
║        Upload files to GitHub WITHOUT cloning!               ║
╚══════════════════════════════════════════════════════════════════╝

USAGE:
    github-upload [options] -r REPO FILE...

OPTIONS:
    -r, --repo REPO           Repository (user/repo or just repo)
    -c, --create              Create repository if it doesn't exist
    -p, --private             Make new repository private
    -d, --description TEXT    Repository description (with -c)
    -m, --message TEXT        Commit message (default: "Upload filename")
    -f, --file-path PATH      Upload single file to this path in repo

    -A, --add-account [NAME]  Add a GitHub account
    -a, --account NAME        Use specific account
    --list-accounts           Show saved accounts

    --delete PATH             Delete a file from repository
    --list [PATH]             List files in repository (optional subfolder)
    --list-repos              List your repositories
    --list-branches           List branches in repository
    -b, --branch NAME         Create new branch
    --target-branch NAME      Upload to specific branch

    -q, --quiet               Quiet mode (minimal output)
    -P, --progress            Progress bar for uploads
    -n, --dry-run             Show what would be uploaded
    -h, --help                Show this help
    --clear                   Clear saved credentials

EXAMPLES:
    github-upload -r my-repo -c app.apk
    github-upload -r my-repo -m "Version 2.0" app.apk
    github-upload -r my-repo -f "apps/android/app.apk" app.apk
    github-upload -r my-repo app.apk icon.png readme.txt
    github-upload -r my-repo -c -p -d "My app" app.apk
    github-upload -r my-repo --delete old-file.txt
    github-upload -r my-repo --list src/
    github-upload -A
    github-upload -a work -r company/repo file.txt

NOTES:
    * Uses GitHub API directly - NO git clone needed!
    * Max file size: 100MB
    * Files upload to repo root by default
    * Use -f to specify upload path (single file only)
    * Credentials stored in ~/.config/github-upload/
    * Set NO_COLOR=1 to disable color output

HELPEOF
}

# ========================
# PARSE ARGUMENTS
# ========================

REPO=""
CREATE_REPO="false"
IS_PRIVATE="false"
REPO_DESCRIPTION=""
COMMIT_MSG=""
FILES=()
SPECIFIED_ACCOUNT=""
DELETE_FILE=""
DO_LIST="false"
LIST_REPOS="false"
LIST_BRANCHES="false"
CREATE_BRANCH="false"
LIST_PATH=""
FILE_PATH=""
BRANCH_NAME=""
SOURCE_BRANCH="main"
TARGET_BRANCH=""
DRY_RUN="false"
QUIET="false"
PROGRESS="false"
SHOW_ACCOUNTS="false"
ADD_ACCOUNT=""
CLEAR_CREDS="false"
OVERWRITE="false"
INTERACTIVE="false"

ORIGINAL_ARGS=$#

while [[ $# -gt 0 ]]; do
    case "$1" in
        -r|--repo)
            REPO="$2"; shift 2 ;;
        -c|--create)
            CREATE_REPO="true"; shift ;;
        -p|--private)
            IS_PRIVATE="true"; shift ;;
        -d|--description)
            REPO_DESCRIPTION="$2"; shift 2 ;;
        -m|--message)
            COMMIT_MSG="$2"; shift 2 ;;
        -f|--file-path)
            FILE_PATH="$2"; shift 2 ;;
        -a|--account)
            SPECIFIED_ACCOUNT="$2"; shift 2 ;;
        # FIX #12: Only consume next arg as account name if it doesn't start with -
        -A|--add-account)
            if [[ $# -gt 1 && "${2:-}" != -* && -n "${2:-}" ]]; then
                ADD_ACCOUNT="$2"; shift 2
            else
                ADD_ACCOUNT=""; shift
            fi
            ;;
        --list-accounts)
            SHOW_ACCOUNTS="true"; shift ;;
        --delete)
            DELETE_FILE="$2"; shift 2 ;;
        --list)
            DO_LIST="true"
            if [[ $# -gt 1 && "${2:-}" != -* ]]; then
                LIST_PATH="$2"; shift
            fi
            shift ;;
        --list-repos)
            LIST_REPOS="true"; shift ;;
        --list-branches)
            LIST_BRANCHES="true"; shift ;;
        -b|--branch)
            CREATE_BRANCH="true"; BRANCH_NAME="$2"; shift 2 ;;
        --source-branch)
            SOURCE_BRANCH="$2"; shift 2 ;;
        --target-branch)
            TARGET_BRANCH="$2"; shift 2 ;;
        -P|--progress)
            PROGRESS="true"; shift ;;
        -q|--quiet)
            QUIET="true"; shift ;;
        -n|--dry-run)
            DRY_RUN="true"; shift ;;
        -h|--help)
            show_help; exit 0 ;;
        --clear)
            CLEAR_CREDS="true"; shift ;;
        --overwrite)
            OVERWRITE="true"; shift ;;
        -i|--interactive)
            INTERACTIVE="true"; shift ;;
        -*)
            log error "Unknown option: $1"; exit 1 ;;
        *)
            FILES+=("$1"); shift ;;
    esac
done

# ========================
# EXECUTE
# ========================

for cmd in curl stat; do
    command -v "$cmd" > /dev/null || { log error "Required command '$cmd' not found"; exit 1; }
done

# FIX #11: Always exit after interactive menu — never fall through to do_upload
if [[ "$INTERACTIVE" == "true" ]]; then
    show_interactive_menu
    exit 0
fi

if [[ $ORIGINAL_ARGS -eq 0 ]]; then
    show_interactive_menu
    exit 0
fi

if [[ "$CLEAR_CREDS" == "true" ]]; then
    rm -rf "$CONFIG_DIR"
    log success "Credentials cleared"
    exit 0
fi

if [[ "$SHOW_ACCOUNTS" == "true" ]]; then
    list_accounts
    exit 0
fi

if [[ -n "$ADD_ACCOUNT" || "$ADD_ACCOUNT" == "" && "$ORIGINAL_ARGS" -eq 1 ]]; then
    add_account "$ADD_ACCOUNT"
    exit 0
fi

if [[ -n "$DELETE_FILE" ]]; then
    do_delete
    exit $?
fi

if [[ "$DO_LIST" == "true" ]]; then
    do_list
    exit $?
fi

handle_list_repos() {
    . "$DEFAULT_CONFIG" 2>/dev/null || { log error "No account configured"; exit 1; }
    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" "https://api.github.com/user/repos?per_page=100")
    echo -e "${BOLD}Your repositories:${NC}"
    echo "$response" | grep -o '"name": "[^"]*"' | sed 's/"name": "//;s/"$//'
    exit 0
}
if [[ "$LIST_REPOS" == "true" ]]; then handle_list_repos; fi

handle_list_branches() {
    [[ -z "$REPO" ]] && { log error "Repository required"; exit 1; }
    . "$DEFAULT_CONFIG" 2>/dev/null || { log error "No account configured"; exit 1; }
    [[ "$REPO" != */* ]] && REPO="$GITHUB_USERNAME/$REPO"
    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$REPO/branches")
    echo -e "${BOLD}Branches in $REPO:${NC}"
    echo "$response" | grep -o '"name": "[^"]*"' | sed 's/"name": "//;s/"$//' | head -10
    exit 0
}
if [[ "$LIST_BRANCHES" == "true" ]]; then handle_list_branches; fi

handle_create_branch() {
    [[ -z "$REPO" ]] && { log error "Repository required"; exit 1; }
    [[ -z "$BRANCH_NAME" ]] && { log error "Branch name required"; exit 1; }
    . "$DEFAULT_CONFIG" 2>/dev/null || { log error "No account configured"; exit 1; }
    [[ "$REPO" != */* ]] && REPO="$GITHUB_USERNAME/$REPO"

    local ref_response sha
    ref_response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$REPO/git/refs/heads/$SOURCE_BRANCH")

    # FIX #9 (in jq_safe): .object.sha now handled correctly
    sha=$(jq_safe "$ref_response" ".object.sha")
    [[ -z "$sha" || "$sha" == "null" ]] && { log error "Branch '$SOURCE_BRANCH' not found"; exit 1; }

    local json tmpfile
    json=$(printf '{"ref":"refs/heads/%s","sha":"%s"}' "$BRANCH_NAME" "$sha")
    tmpfile=$(mktemp)
    printf '%s' "$json" > "$tmpfile"

    # FIX #4: Use -o /dev/null -w "%{http_code}" to cleanly capture status code
    local resp_code
    resp_code=$(curl -s -o /dev/null -w "%{http_code}" -X POST \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        --data-binary "@$tmpfile" \
        "https://api.github.com/repos/$REPO/git/refs")
    rm -f "$tmpfile"

    [[ "$resp_code" == "201" ]] \
        && log success "Branch created: $BRANCH_NAME" \
        || log error "Failed to create branch (HTTP $resp_code)"
    exit 0
}
if [[ "$CREATE_BRANCH" == "true" ]]; then handle_create_branch; fi

do_upload

