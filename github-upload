#!/usr/bin/env bash
################################################################################
# GitHub File Upload Tool
# Upload any files to a GitHub repository from Termux/Unix using gh CLI.
# Supports: txt, pdf, apk, images, archives, any file type.
#
# Usage:
#   github-upload [options] [file1 file2 ...]
#
# Options:
#   -r, --repo REPO        Repository name (user/repo or just repo)
#   -m, --message MSG      Commit message (default: "Upload files via github-upload")
#   -b, --branch BRANCH    Target branch (default: main)
#   -c, --create           Create repository if it doesn't exist
#   -d, --description DESC Repository description when creating
#   --public              Make new repo public (default: public)
#   --private             Make new repo private
#   -h, --help            Show this help message
#
# Configuration:
#   First run will prompt for GitHub credentials and save them to
#   ~/.config/github-upload/config for reuse.
#
# Examples:
#   github-upload file.txt
#   github-upload -r myuser/myrepo file1.pdf file2.apk
#   github-upload -m "Backup from Termux" /sdcard/*
################################################################################

set -euo pipefail

# Configuration
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/github-upload"
CONFIG_FILE="$CONFIG_DIR/config"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Defaults
REPO=""
COMMIT_MSG="Upload files via github-upload"
BRANCH="${GITHUB_DEFAULT_BRANCH:-main}"
CREATE_REPO=false
REPO_DESCRIPTION=""
VISIBILITY="--public"
FILES=()
HELP=false

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        -r|--repo)
            REPO="$2"
            shift 2
            ;;
        -m|--message)
            COMMIT_MSG="$2"
            shift 2
            ;;
        -b|--branch)
            BRANCH="$2"
            shift 2
            ;;
        -c|--create)
            CREATE_REPO=true
            shift
            ;;
        -d|--description)
            REPO_DESCRIPTION="$2"
            shift 2
            ;;
        --public)
            VISIBILITY="--public"
            shift
            ;;
        --private)
            VISIBILITY="--private"
            shift
            ;;
        -h|--help)
            HELP=true
            shift
            ;;
        -*)
            echo -e "${RED}Error: Unknown option $1${NC}" >&2
            exit 1
            ;;
        *)
            FILES+=("$1")
            shift
            ;;
    esac
done

if $HELP; then
    grep '^#' "$0" | sed -n '2,38p' | cut -c4-
    exit 0
fi

# Check dependencies
if ! command -v gh &>/dev/null; then
    echo -e "${RED}Error: GitHub CLI (gh) not installed.${NC}" >&2
    echo "Install in Termux with: pkg install gh" >&2
    exit 1
fi

if ! command -v git &>/dev/null; then
    echo -e "${RED}Error: git not installed.${NC}" >&2
    echo "Install in Termux with: pkg install git" >&2
    exit 1
fi

# Load or prompt for credentials
load_credentials() {
    if [ -f "$CONFIG_FILE" ]; then
        # shellcheck disable=SC1090
        source "$CONFIG_FILE" >/dev/null 2>&1
        return 0
    fi
    return 1
}

save_credentials() {
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" <<EOF
# GitHub Upload credentials - DO NOT SHARE
GITHUB_USERNAME="$GITHUB_USERNAME"
GITHUB_TOKEN="$GITHUB_TOKEN"
EOF
    chmod 600 "$CONFIG_FILE"
}

prompt_credentials() {
    echo -e "${BLUE}GitHub Authentication${NC}"
    read -rp "GitHub username: " GITHUB_USERNAME
    read -rsp "GitHub Personal Access Token (ghp_...): " GITHUB_TOKEN
    echo
    save_credentials
    echo -e "${GREEN}Credentials saved to $CONFIG_FILE${NC}"
}

# Ensure authenticated
if ! load_credentials; then
    prompt_credentials
fi

# Authenticate gh (only needed if not already authenticated)
if ! gh auth status &>/dev/null; then
    echo -e "${BLUE}Authenticating with GitHub...${NC}"
    echo "$GITHUB_TOKEN" | gh auth login --with-token >/dev/null
fi

# Normalize repo name
normalize_repo() {
    local r="$1"
    # If it's just "repo", prepend username
    if [[ "$r" != */* ]]; then
        r="$GITHUB_USERNAME/$r"
    fi
    echo "$r"
}

# Check if repository exists
repo_exists() {
    local repo="$1"
    if gh repo view "$repo" &>/dev/null; then
        return 0
    fi
    return 1
}

# Create repository
create_repository() {
    local repo="$1"
    local desc="$2"
    local vis="$3"

    echo -e "${YELLOW}Creating repository: $repo${NC}"
    if gh repo create "$repo" \
        --description "${desc:-Uploaded via github-upload}" \
        $vis \
        --source . \
        --private \
        --push >/dev/null 2>&1; then
        echo -e "${GREEN}✓ Repository created${NC}"
        return 0
    else
        echo -e "${RED}Error: Failed to create repository${NC}" >&2
        return 1
    fi
}

# Get default branch of repository
get_default_branch() {
    local repo="$1"
    gh repo view "$repo" --json defaultBranchRef --jq '.defaultBranchRef.name' 2>/dev/null || echo "main"
}

# Upload a single file using GitHub API
upload_file() {
    local repo="$1"
    local branch="$2"
    local file_path="$3"
    local message="$4"

    local filename
    filename=$(basename "$file_path")

    # Skip if file doesn't exist
    if [ ! -f "$file_path" ]; then
        echo -e "${YELLOW}Warning: '$file_path' not found, skipping${NC}" >&2
        return 1
    fi

    local file_size
    file_size=$(stat -c%s "$file_path" 2>/dev/null || stat -f%z "$file_path" 2>/dev/null)
    echo -e "${BLUE}Uploading: $filename (${file_size} bytes)${NC}"

    # Check if file exists on repo to get its SHA
    local sha=""
    if gh api "repos/$repo/contents/$filename" \
        --jq '.sha // empty' \
        --headers "Accept: application/vnd.github+json" \
        --ref "$branch" &>/dev/null; then
        sha=$(gh api "repos/$repo/contents/$filename" \
            --jq '.sha' \
            --headers "Accept: application/vnd.github+json" \
            --ref "$branch" 2>/dev/null)
    fi

    # Upload/update file
    echo -e "${BLUE}Encoding file (this may take a while for large files)...${NC}"
    local content
    content=$(base64 -w 0 "$file_path")

    echo -e "${BLUE}Pushing to GitHub...${NC}"
    local payload
    payload=$(printf '{"message":"%s","content":"%s","sha":"%s","branch":"%s"}' \
        "$message" "$content" "$sha" "$branch")

    if gh api "repos/$repo/contents/$filename" \
        --method PUT \
        --body "$payload" \
        --headers "Accept: application/vnd.github+json" \
        --jq '.content.name // .message // empty'; then
        echo -e "  ${GREEN}✓ $filename${NC}"
        return 0
    else
        echo -e "  ${RED}✗ $filename (check file size < 100MB)${NC}" >&2
        return 1
    fi
}

# Main
if $HELP; then exit 0; fi

# Interactive mode for repo
if [ -z "$REPO" ]; then
    echo -e "${BLUE}Repository${NC}"
    read -rp "Repository name (e.g., my-repo or user/repo): " REPO_INPUT
    REPO="$REPO_INPUT"
    if [ -z "$REPO" ]; then
        echo -e "${RED}Error: Repository name required.${NC}" >&2
        exit 1
    fi
fi

REPO="$(normalize_repo "$REPO")"

# Check if repo exists, create if needed
if ! repo_exists "$REPO"; then
    if $CREATE_REPO; then
        create_repository "$REPO" "$REPO_DESCRIPTION" "$VISIBILITY"
    else
        echo -e "${RED}Error: Repository '$REPO' not found.${NC}" >&2
        echo "Use -c/--create to create it automatically." >&2
        exit 1
    fi
else
    echo -e "${GREEN}✓ Repository exists: $REPO${NC}"
fi

# Get actual branch (use provided or repo default)
if [ "$BRANCH" = "${GITHUB_DEFAULT_BRANCH:-main}" ]; then
    BRANCH=$(get_default_branch "$REPO")
fi

# Interactive mode for files
if [ ${#FILES[@]} -eq 0 ]; then
    echo "Enter file paths (one per line, empty line to finish):"
    while IFS= read -r line; do
        [ -z "$line" ] && break
        FILES+=("$line")
        echo "  Added: $line"
    done < /dev/stdin
fi

if [ ${#FILES[@]} -eq 0 ]; then
    echo -e "${RED}Error: No files specified.${NC}" >&2
    exit 1
fi

# Upload files
echo -e "${BLUE}Uploading to $REPO ($BRANCH)${NC}"
success=0
failed=0
for f in "${FILES[@]}"; do
    echo "Processing: $f"
    if [ -f "$f" ]; then
        if upload_file "$REPO" "$BRANCH" "$f" "$COMMIT_MSG"; then
            ((success++))
        else
            ((failed++))
        fi
    else
        echo -e "${YELLOW}Warning: '$f' not found, skipping${NC}" >&2
        ((failed++))
    fi
done

echo ""
if [ $success -gt 0 ]; then
    echo -e "${GREEN}✓ Upload complete: $success file(s)${NC}"
fi
if [ $failed -gt 0 ]; then
    echo -e "${RED}✗ Failed: $failed file(s)${NC}"
fi
echo "View at: https://github.com/$REPO"
