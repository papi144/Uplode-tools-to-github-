#!/usr/bin/env bash
################################################################################
# GitHub Direct Upload Tool
#
# Upload files directly to GitHub via API (NO CLONING NEEDED!)
# Features: No clone, 100MB support, quiet mode, help, delete files, multi-account
################################################################################

set -euo pipefail

# ========================
# CONFIGURATION
# ========================

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/github-upload"
DEFAULT_CONFIG="$CONFIG_DIR/config"
ACCOUNTS_DIR="$CONFIG_DIR/accounts"
MAX_FILE_SIZE=104857600  # 100MB in bytes
LARGE_FILE_SIZE=1048576   # 1MB - files larger than this show progress

# FIX #19: Only use colors if stdout is a TTY and NO_COLOR is not set
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    CYAN='\033[0;36m'
    MAGENTA='\033[0;35m'
    ORANGE='\033[38;5;208m'
    PURPLE='\033[38;5;141m'
    BOLD='\033[1m'
    DIM='\033[2m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' MAGENTA=''
    ORANGE='' PURPLE='' BOLD='' DIM='' NC=''
fi

# Icons
CHECK="${GREEN}[+]"
CROSS="${RED}[x]"
ARROW="${CYAN}->"
BULLET="${ORANGE}*"

# ========================
# HELPER FUNCTIONS
# ========================

log() {
    local type="$1"
    shift
    local msg="$*"

    case "$type" in
        info)    [[ "$QUIET" != "true" ]] && echo -e "${CYAN}[i]${NC} $msg" ;;
        success) [[ "$QUIET" != "true" ]] && echo -e "${GREEN}${CHECK}${NC} $msg" ;;
        warn)    [[ "$QUIET" != "true" ]] && echo -e "${YELLOW}[!]${NC} $msg" ;;
        error)   echo -e "${RED}${CROSS}${NC} $msg" >&2 ;;
        quiet)   : ;;
    esac
}

jq_safe() {
    local json="$1"
    local query="$2"
    if command -v jq > /dev/null 2>&1; then
        echo "$json" | jq -r "$query" 2>/dev/null || echo ""
    else
        case "$query" in
            # FIX #9: Added .object.sha support to jq_safe fallback
            ".object.sha")
                echo "$json" | sed -n 's/.*"sha": *"\([^"]*\)".*/\1/p'
                ;;
            ".sha")
                echo "$json" | sed -n 's/.*"sha": *"\([^"]*\)".*/\1/p'
                ;;
            ".message")
                echo "$json" | grep -o '"message":"[^"]*"' | head -1 | cut -d'"' -f4
                ;;
            *)
                echo "$json" | grep -o '"name":"[^"]*"' | head -1 | cut -d'"' -f4
                ;;
        esac
    fi
}

handle_list_repos_menu() {
    select_account || return
    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" "https://api.github.com/user/repos?per_page=100")
    echo -e "${BOLD}Repositories for $GITHUB_USERNAME:${NC}"
    echo "$response" | grep -o '"name": "[^"]*"' | sed 's/"name": "//;s/"$//'
}

list_repos_for_account() {
    select_account || return

    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" "https://api.github.com/user/repos?per_page=100")
    echo -e "${BOLD}Repositories for $GITHUB_USERNAME:${NC}"
    echo "$response" | grep -o '"name": "[^"]*"' | sed 's/"name": "//;s/"$//'
}

show_progress() {
    local current=$1
    local total=$2
    local file=$3
    local percent=$((current * 100 / total))
    local hashes=$((percent / 2))
    local bar=""
    if [[ $hashes -gt 0 ]]; then
        bar=$(printf '#%.0s' $(seq 1 $hashes))
    fi

    local file_size
    file_size=$(stat -c%s "$file" 2>/dev/null) || file_size=$(stat -f%z "$file" 2>/dev/null)

    local size_mb=$((file_size / 1048576))
    local total_mb=$((total * file_size / 1048576))

    if [[ $total -gt 1 ]]; then
        printf "\r${GREEN}[%-50s${NC}] %3d%% (%d/%d) %s (%dMB)" "$bar" "$percent" "$current" "$total" "$(basename "$file")" "$size_mb"
    else
        printf "\r${GREEN}[%-50s${NC}] %3d%% %s (%dMB)" "$bar" "$percent" "$(basename "$file")" "$size_mb"
    fi
}

get_mime_type() {
    local file="$1"
    local ext="${file##*.}"
    case "$ext" in
        apk) echo "application/vnd.android.package-archive" ;;
        ipa) echo "application/iphone" ;;
        jar) echo "application/java-archive" ;;
        zip) echo "application/zip" ;;
        tar) echo "application/x-tar" ;;
        gz)  echo "application/gzip" ;;
        pdf) echo "application/pdf" ;;
        txt) echo "text/plain" ;;
        json) echo "application/json" ;;
        xml) echo "application/xml" ;;
        html) echo "text/html" ;;
        js)  echo "application/javascript" ;;
        sh)  echo "application/x-sh" ;;
        py)  echo "text/x-python" ;;
        md)  echo "text/markdown" ;;
        png) echo "image/png" ;;
        jpg) echo "image/jpeg" ;;
        gif) echo "image/gif" ;;
        svg) echo "image/svg+xml" ;;
        mp3) echo "audio/mpeg" ;;
        mp4) echo "video/mp4" ;;
        *)   echo "application/octet-stream" ;;
    esac
}

# ========================
# ACCOUNT MANAGEMENT
# ========================

add_account() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        read -rp "Account name (e.g., personal, work): " name
        [[ -n "$name" ]] || { echo "Account name required"; exit 1; }
    fi

    local config_dir="$ACCOUNTS_DIR/$name"
    local config_file="$config_dir/config"

    if [[ -e "$config_file" && "${OVERWRITE:-}" != "true" ]]; then
        read -rp "Account '$name' exists. Overwrite? (y/N): " overwrite
        [[ "$overwrite" =~ ^[Yy]$ ]] || { echo "Aborted."; return; }
    fi

    echo -e "${CYAN}Adding account: $name${NC}"
    read -rp "GitHub username: " user
    read -rsp "GitHub Personal Access Token: " token
    echo

    mkdir -p "$config_dir"
    # FIX #10: Use printf %q to safely quote values — prevents special chars in token
    # from being interpreted (e.g. $, backticks, backslashes)
    printf 'GITHUB_USERNAME=%q\nGITHUB_TOKEN=%q\n' "$user" "$token" > "$config_file"
    chmod 600 "$config_file"
    echo -e "${GREEN}${CHECK} Account '${name}' saved.${NC}"
}

list_accounts() {
    echo "Configured accounts:"
    local count=0

    if [[ -f "$DEFAULT_CONFIG" ]]; then
        local user
        user=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" 2>/dev/null | cut -d= -f2- | tr -d '"' || echo "unknown")
        echo -e "  ${BLUE}default${NC}: $user ${GREEN}(you are here)${NC}"
        count=$((count + 1))
    fi

    if [[ -d "$ACCOUNTS_DIR" ]]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [[ -f "$cfg" ]] || continue
            local acc
            acc=$(basename "$(dirname "$cfg")")
            local u
            u=$(grep '^GITHUB_USERNAME=' "$cfg" 2>/dev/null | cut -d= -f2- | tr -d '"' || echo "unknown")
            echo -e "  ${BLUE}$acc${NC}: $u"
            count=$((count + 1))
        done
    fi

    [[ $count -eq 0 ]] && echo "  (none configured)"
    echo
}

load_account() {
    local name="$1"

    # FIX #1: Don't unset before checking. If credentials already loaded, reuse them.
    if [[ -n "${GITHUB_TOKEN:-}" && -n "${GITHUB_USERNAME:-}" ]]; then
        return 0
    fi

    if [[ -z "$name" ]] || [[ "$name" == "default" ]]; then
        if [[ -f "$DEFAULT_CONFIG" ]]; then
            # shellcheck disable=SC1090
            source "$DEFAULT_CONFIG"
        fi
        [[ -n "${GITHUB_USERNAME:-}" && -n "${GITHUB_TOKEN:-}" ]] && return 0
        return 1
    else
        local cfg="$ACCOUNTS_DIR/$name/config"
        if [[ -f "$cfg" ]]; then
            # shellcheck disable=SC1090
            source "$cfg"
        fi
        [[ -n "${GITHUB_USERNAME:-}" && -n "${GITHUB_TOKEN:-}" ]] && return 0
        return 1
    fi
}

verify_account() {
    local response
    response=$(curl -s -w "\n%{http_code}" -H "Authorization: Bearer $GITHUB_TOKEN" "https://api.github.com/user")
    local code="${response##*$'\n'}"
    local body="${response%$'\n'*}"

    if [[ "$code" == "200" ]]; then
        local username
        username=$(echo "$body" | grep -o '"login":"[^"]*"' | head -1 | cut -d'"' -f4)
        echo "$username"
        return 0
    fi
    return 1
}

# ========================
# REPO OPERATIONS
# ========================

check_repo() {
    local repo="$1"
    # FIX #15 pattern: use -o /dev/null to isolate HTTP code
    curl -s -o /dev/null -w "%{http_code}" \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$repo"
}

create_repo() {
    local repo_owner="$1"
    local repo_name="$2"
    local is_private="${3:-false}"
    local description="${4:-}"

    local json
    if [[ -n "$description" ]]; then
        json="{\"name\":\"$repo_name\",\"description\":\"$description\",\"private\":$is_private}"
    else
        json="{\"name\":\"$repo_name\",\"private\":$is_private}"
    fi

    local api_url
    if [[ "$repo_owner" == "$GITHUB_USERNAME" ]]; then
        api_url="https://api.github.com/user/repos"
    else
        api_url="https://api.github.com/orgs/$repo_owner/repos"
    fi

    local tmpfile
    tmpfile=$(mktemp)
    printf '%s' "$json" > "$tmpfile"

    local body code
    body=$(curl -s -X POST \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        --data-binary "@$tmpfile" \
        "$api_url")
    code=$(curl -s -o /dev/null -w "%{http_code}" -X POST \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        --data-binary "@$tmpfile" \
        "$api_url")
    rm -f "$tmpfile"

    if [[ "$code" == "201" ]] || [[ "$code" == "200" ]]; then
        log success "Repository created"
        return 0
    else
        local msg
        msg=$(echo "$body" | grep -o '"message":"[^"]*"' | head -1 | cut -d'"' -f4)
        log error "Failed to create repo: $msg"
        return 1
    fi
}

# ========================
# FILE OPERATIONS (Direct API - NO CLONING!)
# ========================

upload_file() {
    local repo="$1"
    local file_path="$2"
    local repo_path="${3:-$(basename "$file_path")}"
    local commit_msg="${4:-Upload $repo_path}"

    if [[ ! -f "$file_path" ]]; then
        log error "File not found: $file_path"
        return 1
    fi

    # FIX #17: Handle stat failure gracefully on both Linux and macOS
    local file_size=""
    file_size=$(stat -c%s "$file_path" 2>/dev/null) \
        || file_size=$(stat -f%z "$file_path" 2>/dev/null) \
        || { log error "Cannot determine file size for: $file_path"; return 1; }

    if [[ $file_size -gt $MAX_FILE_SIZE ]]; then
        log warn "File too large for contents API: $file_size bytes"
        log info "Uploading via GitHub Releases..."
        if upload_to_release "$repo" "$file_path" "$repo_path" "$commit_msg"; then
            return 0
        else
            return 1
        fi
    fi

    # FIX #18: Portable base64 — detect flag support, strip newlines on macOS
    local content
    if base64 --help 2>&1 | grep -q '\-w'; then
        content=$(base64 -w 0 "$file_path")
    else
        content=$(base64 "$file_path" | tr -d '\n')
    fi

    # FIX #6: Use jq_safe (works with or without jq) instead of raw jq for SHA
    local sha_response existing_sha sha=""
    sha_response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$repo/contents/$repo_path")
    existing_sha=$(jq_safe "$sha_response" ".sha")

    if [[ -n "$existing_sha" && "$existing_sha" != "null" ]]; then
        sha="$existing_sha"
        log info "File exists, updating..."
    fi

    # Build JSON payload
    local json
    if [[ -n "$sha" && -n "$TARGET_BRANCH" ]]; then
        json=$(printf '{"message":"%s","content":"%s","sha":"%s","branch":"%s"}' \
            "$commit_msg" "$content" "$sha" "$TARGET_BRANCH")
    elif [[ -n "$sha" ]]; then
        json=$(printf '{"message":"%s","content":"%s","sha":"%s"}' \
            "$commit_msg" "$content" "$sha")
    elif [[ -n "$TARGET_BRANCH" ]]; then
        json=$(printf '{"message":"%s","content":"%s","branch":"%s"}' \
            "$commit_msg" "$content" "$TARGET_BRANCH")
    else
        json=$(printf '{"message":"%s","content":"%s"}' \
            "$commit_msg" "$content")
    fi

    local tmpfile
    tmpfile=$(mktemp)
    printf '%s' "$json" > "$tmpfile"

local api_url="https://api.github.com/repos/$repo/contents/$repo_path"

    local curl_opts="-s -o /tmp/upload_response.json"
    if [[ $file_size -gt $LARGE_FILE_SIZE ]]; then
        curl_opts="$curl_opts --progress-bar"
    fi
    curl_opts="$curl_opts -w \"%{http_code}\""

    local http_code
    http_code=$(eval curl $curl_opts -X PUT \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        -H "Content-Type: application/json" \
        --data-binary "@$tmpfile" \
        "$api_url")

    local body
    body=$(cat /tmp/upload_response.json)
    rm -f "$tmpfile" /tmp/upload_response.json

    if [[ "$http_code" == "200" ]] || [[ "$http_code" == "201" ]]; then
        log success "Uploaded: $repo_path"
        return 0
    else
        local msg
        msg=$(jq_safe "$body" ".message")
        [[ -z "$msg" ]] && msg="Unknown error"
        log error "Failed: $msg"
        return 1
    fi
}

upload_to_release() {
    local repo="$1"
    local file_path="$2"
    local file_name="${3:-$(basename "$file_path")}"
    local commit_msg="${4:-Upload $file_name to release}"

    if [[ ! -f "$file_path" ]]; then
        log error "File not found: $file_path"
        return 1
    fi

    local file_size
    file_size=$(stat -c%s "$file_path" 2>/dev/null) || file_size=$(stat -f%z "$file_path" 2>/dev/null)

    local owner="${repo%%/*}"
    local reponame="${repo##*/}"

    log info "Creating release..."

    local release_json
    release_json=$(printf '{"tag_name":"v%s","name":"%s release","draft":false}' "$file_name" "$file_name")
    local tmpfile
    tmpfile=$(mktemp)
    printf '%s' "$release_json" > "$tmpfile"

    local release_resp
    release_resp=$(curl -s -X POST \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        --data-binary "@$tmpfile" \
        "https://api.github.com/repos/$owner/$reponame/releases")
    rm -f "$tmpfile"

    local release_id
    release_id=$(echo "$release_resp" | sed -n 's/.*"id": *\([0-9]*\).*/\1/p')

    if [[ -z "$release_id" || "$release_id" == "null" ]]; then
        local existing
        existing=$(curl -s -X GET \
            -H "Authorization: Bearer $GITHUB_TOKEN" \
            -H "Accept: application/vnd.github+json" \
            "https://api.github.com/repos/$owner/$reponame/releases/tags/$file_name")
        release_id=$(echo "$existing" | sed -n 's/.*"id": *\([0-9]*\).*/\1/p')
    fi

    if [[ -z "$release_id" || "$release_id" == "null" ]]; then
        log error "Failed to create/get release"
        return 1
    fi

    log info "Uploading to release..."

    local upload_url="https://uploads.github.com/repos/$owner/$reponame/releases/$release_id/assets?name=$file_name"

    local content_type
    content_type=$(get_mime_type "$file_path")

    local upload_resp
    upload_resp=$(curl -s -X POST \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        -H "Content-Type: $content_type" \
        --data-binary "@$file_path" \
        "$upload_url")

    if echo "$upload_resp" | grep -q '"browser_download_url"'; then
        local download_url
        download_url=$(echo "$upload_resp" | sed -n 's/.*"browser_download_url": *"\([^"]*\)".*/\1/p')
        log success "Uploaded to release: $download_url"
        return 0
    else
        log error "Release upload failed"
        return 1
    fi
}

delete_file() {
    local repo="$1"
    local repo_path="$2"
    local commit_msg="${3:-Delete $repo_path}"

    local sha_response sha
    sha_response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$repo/contents/$repo_path")
    sha=$(jq_safe "$sha_response" ".sha")

    if [[ -z "$sha" || "$sha" == "null" ]]; then
        log error "File not found: $repo_path"
        return 1
    fi

    local tmpfile
    tmpfile=$(mktemp)
    printf '{"message":"%s","sha":"%s"}' "$commit_msg" "$sha" > "$tmpfile"

    local http_code
    http_code=$(curl -s -o /tmp/delete_response.json -w "%{http_code}" -X DELETE \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        -H "Content-Type: application/json" \
        --data-binary "@$tmpfile" \
        "https://api.github.com/repos/$repo/contents/$repo_path")
    local body
    body=$(cat /tmp/delete_response.json)
    rm -f "$tmpfile" /tmp/delete_response.json

    if [[ "$http_code" == "200" ]] || [[ "$http_code" == "204" ]]; then
        log success "Deleted: $repo_path"
        return 0
    else
        local msg
        msg=$(jq_safe "$body" ".message")
        [[ -z "$msg" ]] && msg="Unknown error"
        log error "Failed: $msg (HTTP $code)"
        return 1
    fi
}

list_files() {
    local repo="$1"
    local path="${2:-}"

    local url="https://api.github.com/repos/$repo/contents"
    [[ -n "$path" ]] && url="$url/$path"

    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" "$url")

    # FIX #14: Match only a top-level error object, not a file named "message.*"
    if echo "$response" | grep -qE '^\{[[:space:]]*"message"'; then
        log error "Failed to list files"
        return 1
    fi

    echo -e "${BOLD}Files in $repo${NC}:"
    if command -v jq > /dev/null 2>&1; then
        echo "$response" | jq -r 'if type == "array" then .[] else . end | .name' 2>/dev/null \
            || echo "$response" | sed -n 's/.*"name": "\([^"]*\)".*/\1/p'
    else
        echo "$response" | sed -n 's/.*"name": "\([^"]*\)".*/\1/p'
    fi
}

# ========================
# MAIN LOGIC
# ========================

resolve_account() {
    local repo_input="$1"

    if [[ -n "$SPECIFIED_ACCOUNT" ]]; then
        if ! load_account "$SPECIFIED_ACCOUNT"; then
            log error "Account '$SPECIFIED_ACCOUNT' not found."
            exit 1
        fi
        return 0
    fi

    local accounts=()
    [[ -f "$DEFAULT_CONFIG" ]] && accounts+=("default")
    [[ -d "$ACCOUNTS_DIR" ]] && for cfg in "$ACCOUNTS_DIR"/*/config; do
        [[ -f "$cfg" ]] && accounts+=("$(basename "$(dirname "$cfg")")")
    done

    if [[ ${#accounts[@]} -eq 0 ]]; then
        log error "No accounts configured. Run with -A to add one."
        exit 1
    fi

    for acc in "${accounts[@]}"; do
        if load_account "$acc" 2>/dev/null; then
            if verify_account > /dev/null 2>&1; then
                if [[ "$acc" != "default" ]] || [[ -n "$SPECIFIED_ACCOUNT" ]]; then
                    log info "Using account: $acc"
                fi
                return 0
            fi
        fi
    done

    log error "No valid account found."
    exit 1
}

do_upload() {
    [[ -z "$REPO" ]] && { log error "Repository required. Use -r repo"; exit 1; }
    [[ ${#FILES[@]} -eq 0 ]] && { log error "No files specified."; exit 1; }

    if [[ -z "${GITHUB_TOKEN:-}" ]]; then
        resolve_account "$REPO"
    fi

    if [[ -z "${GITHUB_USERNAME:-}" ]]; then
        GITHUB_USERNAME=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" 2>/dev/null | cut -d= -f2- | tr -d '"')
    fi

    if [[ "$REPO" != */* ]]; then
        REPO="$GITHUB_USERNAME/$REPO"
    fi

    local code
    code=$(check_repo "$REPO")

    if [[ "$code" == "404" ]]; then
        if [[ "$CREATE_REPO" == "true" ]]; then
            local owner="${REPO%%/*}"
            local name="${REPO##*/}"
            create_repo "$owner" "$name" "$IS_PRIVATE" "$REPO_DESCRIPTION"
        else
            log error "Repository not found: $REPO"
            echo "Use -c to create it"
            exit 1
        fi
    elif [[ "$code" != "200" ]]; then
        log error "Cannot access repository: $REPO (HTTP $code)"
        exit 1
    fi

    local success=0
    local failed=0
    local total=${#FILES[@]}
    local current=0

    for file in "${FILES[@]}"; do
        current=$((current + 1))
        if [[ -f "$file" ]]; then
            local file_size
            file_size=$(stat -c%s "$file" 2>/dev/null) || file_size=$(stat -f%z "$file" 2>/dev/null)

            if [[ "$PROGRESS" == "true" ]] || [[ $total -gt 1 ]] || [[ $file_size -gt $LARGE_FILE_SIZE ]]; then
                show_progress "$current" "$total" "$file"
            else
                [[ "$QUIET" != "true" ]] && echo -e "${CYAN}${ARROW}${NC} Upload: ${PURPLE}$(basename "$file")${NC}"
            fi

            if [[ "$DRY_RUN" == "true" ]]; then
                log info "Would upload: $file"
            else
                # FIX #7: With multiple files, use each file's own basename as path
                # Only use FILE_PATH for single-file uploads
                local effective_path
                if [[ $total -gt 1 || -z "$FILE_PATH" ]]; then
                    effective_path="$(basename "$file")"
                else
                    effective_path="$FILE_PATH"
                fi

                if upload_file "$REPO" "$file" "$effective_path" "$COMMIT_MSG"; then
                    success=$((success + 1))
                else
                    failed=$((failed + 1))
                fi
            fi
        else
            log warn "File not found: $file"
            failed=$((failed + 1))
        fi
    done

    [[ "$PROGRESS" == "true" ]] && echo
    echo

    if [[ "$DRY_RUN" != "true" ]]; then
        [[ $success -gt 0 ]] && log success "Uploaded $success file(s)"
        [[ $failed -gt 0 ]] && log warn "Failed: $failed file(s)"
        [[ $success -gt 0 ]] && echo -e "${GREEN}View at: https://github.com/$REPO${NC}"
    fi

    [[ $failed -gt 0 ]] && exit 1
}

do_delete() {
    [[ -z "$REPO" ]] && { log error "Repository required. Use -r repo"; exit 1; }
    [[ -z "$DELETE_FILE" ]] && { log error "File to delete required. Use --delete path/to/file"; exit 1; }

    if [[ -z "${GITHUB_TOKEN:-}" ]]; then
        resolve_account "$REPO"
    fi

    if [[ -z "${GITHUB_USERNAME:-}" ]]; then
        GITHUB_USERNAME=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" 2>/dev/null | cut -d= -f2- | tr -d '"')
    fi

    [[ "$REPO" != */* ]] && REPO="$GITHUB_USERNAME/$REPO"

    delete_file "$REPO" "$DELETE_FILE" "$COMMIT_MSG"
}

do_list() {
    [[ -z "$REPO" ]] && { log error "Repository required. Use -r repo"; exit 1; }

    if [[ -z "${GITHUB_TOKEN:-}" ]]; then
        if [[ -f "$DEFAULT_CONFIG" ]]; then
            source "$DEFAULT_CONFIG"
        else
            log error "No account configured. Run -A to add one."
            exit 1
        fi
    fi

    if [[ -z "${GITHUB_USERNAME:-}" ]]; then
        GITHUB_USERNAME=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" 2>/dev/null | cut -d= -f2- | tr -d '"')
    fi

    [[ "$REPO" != */* ]] && REPO="$GITHUB_USERNAME/$REPO"

    # FIX #8: Pass LIST_PATH to list_files (was ignored before)
    list_files "$REPO" "${LIST_PATH:-}"
}

select_account() {
    echo -e "${BOLD}Available accounts:${NC}"

    local accounts=()
    local count=1
    local default_user=""

    if [[ -f "$DEFAULT_CONFIG" ]]; then
        default_user=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" 2>/dev/null | cut -d= -f2- | tr -d '"')
    fi

    if [[ -n "$default_user" ]]; then
        echo -e "  ${CYAN}$count)${NC} default: $default_user"
        accounts+=("default|$default_user")
        count=$((count + 1))
    fi

    if [[ -d "$ACCOUNTS_DIR" ]]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [[ -f "$cfg" ]] || continue
            local acc
            acc=$(basename "$(dirname "$cfg")")
            local u
            u=$(grep '^GITHUB_USERNAME=' "$cfg" 2>/dev/null | cut -d= -f2- | tr -d '"')
            [[ "$u" == "$default_user" ]] && continue
            [[ -z "$u" ]] && u="(no username)"
            echo -e "  ${CYAN}$count)${NC} $acc: $u"
            accounts+=("$acc|$u")
            count=$((count + 1))
        done
    fi

    if [[ ${#accounts[@]} -eq 0 ]]; then
        echo "  (no accounts configured)"
        return 1
    fi

    echo
    read -rp "Select account [1-${#accounts[@]}]: " choice

    if [[ -z "$choice" ]] || ! [[ "$choice" =~ ^[0-9]+$ ]] \
        || [[ "$choice" -lt 1 ]] || [[ "$choice" -gt ${#accounts[@]} ]]; then
        log error "Invalid selection"
        return 1
    fi

    local selected="${accounts[$((choice - 1))]}"
    local acc_name="${selected%|*}"

    if [[ "$acc_name" == "default" ]]; then
        . "$DEFAULT_CONFIG"
    else
        . "$ACCOUNTS_DIR/$acc_name/config"
    fi

    if [[ -z "${GITHUB_USERNAME:-}" ]]; then
        if [[ "$acc_name" == "default" ]]; then
            GITHUB_USERNAME=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" 2>/dev/null | cut -d= -f2- | tr -d '"')
        else
            GITHUB_USERNAME=$(grep '^GITHUB_USERNAME=' "$ACCOUNTS_DIR/$acc_name/config" 2>/dev/null | cut -d= -f2- | tr -d '"')
        fi
    fi

    if [[ -z "${GITHUB_USERNAME:-}" ]]; then
        log error "Account '$acc_name' has no username. Please remove and re-add it."
        return 1
    fi

    local response
    response=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" "https://api.github.com/user" 2>/dev/null)
    if echo "$response" | grep -q '"login"'; then
        return 0
    else
        log error "Account credentials are invalid. Please remove and re-add this account."
        return 1
    fi
}

get_file_emoji() {
    local file="$1"
    local ext="${file##*.}"
    case "${ext,,}" in
        apk) echo "📦" ;;
        ipa) echo "📱" ;;
        jar) echo "☕" ;;
        zip|rar|7z|tar|gz) echo "🗜️" ;;
        pdf) echo "📕" ;;
        doc|docx) echo "📝" ;;
        xls|xlsx) echo "📊" ;;
        ppt|pptx) echo "📑" ;;
        txt|md|rst) echo "📄" ;;
        py)  echo "🐍" ;;
        js)  echo "📜" ;;
        html|css) echo "🌐" ;;
        json|xml|yaml|yml) echo "📋" ;;
        sh|bash) echo "⚡" ;;
        go)  echo "🐹" ;;
        rs)  echo "🦀" ;;
        java) echo "☕" ;;
        kt|kts) echo "🤖" ;;
        swift) echo "🍎" ;;
        c|cpp|h) echo "⚙️" ;;
