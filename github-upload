#!/usr/bin/env bash
################################################################################
# GitHub File Upload Tool
#
# Upload files to GitHub repositories from the command line.
# Supports multiple accounts, automatic account detection, and repository creation.
#
# Usage:
#   github-upload [OPTIONS] [FILES...]
#
# Options:
#   -r, --repo REPO        Repository name (format: user/repo or just repo)
#   -m, --message MSG      Commit message (default: "Upload files via github-upload")
#   -b, --branch BRANCH    Target branch (default: repository's default branch)
#   -a, --account NAME     Use specific account (default: auto-detect)
#   -A, --add-account [NAME] Add a new account (prompts for credentials)
#   -c, --create           Create repository if it doesn't exist
#   -d, --description DESC Repository description when creating
#   --public               Make new repository public (default)
#   --private              Make new repository private
#   -h, --help             Show this help message
#
# Accounts:
#   Credentials are stored in:
#     ~/.config/github-upload/config              (default account)
#     ~/.config/github-upload/accounts/<name>/config  (named accounts)
#
#   Environment variables (override config files):
#     GITHUB_USERNAME, GITHUB_TOKEN               (default account)
#     GITHUB_USERNAME_<NAME>, GITHUB_TOKEN_<NAME> (named account, uppercase)
#
# Examples:
#   github-upload file.txt
#   github-upload -r myuser/myrepo file1.pdf file2.apk
#   github-upload -c -r new-repo *.zip
#   github-upload -a work -r company/repo backup.tar.gz
#   github-upload -A personal
#   github-upload --help
#
# Interactive Mode:
#   Run without arguments: github-upload
#   Shows a menu to upload files, add accounts, or list accounts.
#
# Multi-Account Features:
#   - Auto-detects which account has access to a repository
#   - If multiple accounts can access, you choose which to use
#   - If no account can access but using -c, you pick which account creates it
#
# Requirements:
#   - git
#   - curl
################################################################################

set -euo pipefail

# Configuration
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/github-upload"
DEFAULT_CONFIG="$CONFIG_DIR/config"
ACCOUNTS_DIR="$CONFIG_DIR/accounts"

# Colors (modern palette)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# Parse arguments
REPO=""
COMMIT_MSG="Upload files via github-upload"
BRANCH=""
CREATE_REPO=false
REPO_DESCRIPTION=""
VISIBILITY="--public"
FILES=()
HELP=false
ADD_ACCOUNT=false
ADD_ACCOUNT_NAME=""
SPECIFIED_ACCOUNT=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -r|--repo) REPO="$2"; shift 2 ;;
        -m|--message) COMMIT_MSG="$2"; shift 2 ;;
        -b|--branch) BRANCH="$2"; shift 2 ;;
        -a|--account) SPECIFIED_ACCOUNT="$2"; shift 2 ;;
        -A|--add-account) ADD_ACCOUNT=true; ADD_ACCOUNT_NAME="${2:-}"; shift 2 ;;
        -c|--create) CREATE_REPO=true; shift ;;
        -d|--description) REPO_DESCRIPTION="$2"; shift 2 ;;
        --public) VISIBILITY="--public"; shift ;;
        --private) VISIBILITY="--private"; shift ;;
        -h|--help) HELP=true; shift ;;
        -*) echo -e "${RED}Error: Unknown option $1${NC}" >&2; exit 1 ;;
        *) FILES+=("$1"); shift ;;
    esac
done

if $HELP; then
    grep '^#' "$0" | sed -n '2,39p' | cut -c4-
    exit 0
fi

if $ADD_ACCOUNT; then
    add_account "$ADD_ACCOUNT_NAME"
    exit 0
fi

# Check dependencies
for cmd in git curl; do
    command -v "$cmd" >/dev/null || {
        echo -e "${RED}Error: Required command '$cmd' not found.${NC}" >&2
        echo "Install git and curl to use this tool." >&2
        exit 1
    }
done

# -------------------------- Functions --------------------------

add_account() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        read -rp "Account name (e.g., personal, work): " name
        [ -n "$name" ] || { echo "Account name required" >&2; exit 1; }
    fi
    local config_dir="$ACCOUNTS_DIR/$name"
    local config_file="$config_dir/config"
    if [ -e "$config_file" ]; then
        read -rp "Account '$name' exists. Overwrite? (y/N): " overwrite
        [[ "$overwrite" =~ ^[Yy]$ ]] || { echo "Aborted."; return; }
    fi
    echo -e "${CYAN}Adding account: $name${NC}"
    read -rp "GitHub username: " user
    read -rsp "GitHub Personal Access Token (repo scope): " token
    echo
    mkdir -p "$config_dir"
    cat > "$config_file" <<EOF
GITHUB_USERNAME="$user"
GITHUB_TOKEN="$token"
EOF
    chmod 600 "$config_file"
    echo -e "${GREEN}✓ Account '$name' saved.${NC}"
}

list_accounts() {
    echo "Configured accounts:"
    local count=0
    if [ -f "$DEFAULT_CONFIG" ]; then
        local user
        user=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" | cut -d= -f2- || echo "unknown")
        echo -e "  ${CYAN}default${NC}: $user"
        ((count++))
    fi
    if [ -d "$ACCOUNTS_DIR" ]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [ -f "$cfg" ] || continue
            local acc="$(basename "$(dirname "$cfg")")"
            local u
            u=$(grep '^GITHUB_USERNAME=' "$cfg" | cut -d= -f2- || echo "unknown")
            echo -e "  ${CYAN}$acc${NC}: $u"
            ((count++))
        done
    fi
    [ $count -eq 0 ] && echo "  (none configured)"
    echo
}

load_account() {
    local name="$1"
    unset GITHUB_USERNAME GITHUB_TOKEN 2>/dev/null

    if [ -z "$name" ] || [ "$name" = "default" ]; then
        if [ -f "$DEFAULT_CONFIG" ]; then
            # shellcheck disable=SC1090
            source "$DEFAULT_CONFIG"
            [ -n "${GITHUB_USERNAME:-}" ] && [ -n "${GITHUB_TOKEN:-}" ] && return 0
        fi
        if [ -n "${GITHUB_USERNAME:-}" ] && [ -n "${GITHUB_TOKEN:-}" ]; then
            return 0
        fi
        return 1
    else
        local cfg="$ACCOUNTS_DIR/$name/config"
        if [ -f "$cfg" ]; then
            # shellcheck disable=SC1090
            source "$cfg"
            [ -n "${GITHUB_USERNAME:-}" ] && [ -n "${GITHUB_TOKEN:-}" ] && return 0
        fi
        local eu="GITHUB_USERNAME_${name^^}"
        local et="GITHUB_TOKEN_${name^^}"
        if [ -n "${!eu:-}" ] && [ -n "${!et:-}" ]; then
            GITHUB_USERNAME="${!eu}"
            GITHUB_TOKEN="${!et}"
            return 0
        fi
        return 1
    fi
}

check_repo_access() {
    local repo="$1"
    local token="${2:-$GITHUB_TOKEN}"
    local url="https://api.github.com/repos/$repo"
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" -H "Authorization: Bearer $token" "$url")
    [ "$code" = "200" ]
}

create_repo() {
    local repo_owner="${REPO%%/*}"
    local repo_name="${REPO##*/}"
    local is_private="false"
    [ "$VISIBILITY" = "--private" ] && is_private="true"

    local json
    if [ -n "$REPO_DESCRIPTION" ]; then
        local desc_esc
        desc_esc=$(printf '%s' "$REPO_DESCRIPTION" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))' 2>/dev/null || printf '%s' "$REPO_DESCRIPTION" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')
        json="{\"name\":\"$repo_name\",\"description\":\"$desc_esc\",\"private\":$is_private}"
    else
        json="{\"name\":\"$repo_name\",\"private\":$is_private}"
    fi

    local api_url
    if [ "$repo_owner" = "$GITHUB_USERNAME" ]; then
        api_url="https://api.github.com/user/repos"
    else
        api_url="https://api.github.com/orgs/$repo_owner/repos"
    fi

    local response code
    response=$(curl -s -w "\n%{http_code}" -X POST \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        -d "$json" \
        "$api_url")
    code=$(printf "%s" "$response" | tail -n1)

    if [ "$code" = "201" ] || [ "$code" = "200" ]; then
        echo -e "${GREEN}✓ Repository created${NC}"
    else
        echo -e "${RED}Error: Failed to create repository (HTTP $code)${NC}" >&2
        exit 1
    fi
}

upload_files() {
    local repo="$1"
    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" EXIT

    echo -e "${BLUE}Cloning repository...${NC}"
    if ! git clone "https://$GITHUB_USERNAME:$GITHUB_TOKEN@github.com/$repo.git" "$tmpdir" --single-branch 2>/dev/null; then
        echo -e "${RED}Error: Failed to clone repository${NC}" >&2
        return 1
    fi
    echo -e "${GREEN}Repository cloned${NC}"
    cd "$tmpdir"

    if [ -n "$BRANCH" ]; then
        if ! git checkout "$BRANCH" 2>/dev/null; then
            echo -e "${YELLOW}Branch '$BRANCH' not found, creating it${NC}"
            git checkout -b "$BRANCH" || true
        fi
    fi

    echo -e "${BLUE}Copying files...${NC}"
    local success=0
    for f in "${FILES[@]}"; do
        if [ -f "$f" ]; then
            cp "$f" ./
            echo "  + $(basename "$f")"
            ((success++))
        else
            echo -e "${YELLOW}Warning: '$f' not found, skipping${NC}" >&2
        fi
    done
    [ $success -gt 0 ] || { echo -e "${RED}Error: No files to upload${NC}" >&2; return 1; }

    git add -A
    git diff --cached --quiet && { echo -e "${YELLOW}No changes to commit${NC}"; return 0; }

    echo -e "${BLUE}Committing...${NC}"
    git commit -m "$COMMIT_MSG"

    echo -e "${BLUE}Pushing...${NC}"
    if git push origin HEAD; then
        echo -e "${GREEN}✓ Upload complete!${NC}"
        echo -e "View at: ${BOLD}https://github.com/$repo${NC}"
        return 0
    else
        echo -e "${RED}✗ Push failed${NC}" >&2
        return 1
    fi
}

resolve_account() {
    local repo_input="$1"
    
    # Build list of all configured accounts
    local accounts=()
    if [ -f "$DEFAULT_CONFIG" ]; then
        accounts+=("default")
    fi
    if [ -d "$ACCOUNTS_DIR" ]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [ -f "$cfg" ] || continue
            accounts+=("$(basename "$(dirname "$cfg")")")
        done
    fi

    # No accounts? Prompt for one now
    if [ ${#accounts[@]} -eq 0 ]; then
        echo -e "${YELLOW}No accounts configured. Let's set one up.${NC}"
        add_account "default"
        accounts=("default")
    fi

    # If specific account requested, use it
    if [ -n "$SPECIFIED_ACCOUNT" ]; then
        if ! load_account "$SPECIFIED_ACCOUNT"; then
            echo -e "${RED}Error: Account '$SPECIFIED_ACCOUNT' not found.${NC}" >&2
            exit 1
        fi
        # Normalize repo
        if [[ "$repo_input" == */* ]]; then
            REPO="$repo_input"
        else
            REPO="$GITHUB_USERNAME/$repo_input"
        fi
        return
    fi

    # Check each account for repo access
    declare -a accessible=()
    for acc in "${accounts[@]}"; do
        if ! load_account "$acc"; then
            continue
        fi
        local candidate_repo="$repo_input"
        [[ "$candidate_repo" != */* ]] && candidate_repo="$GITHUB_USERNAME/$candidate_repo"
        if check_repo_access "$candidate_repo"; then
            accessible+=("$acc")
        fi
    done

    local chosen=""

    if [ ${#accessible[@]} -eq 1 ]; then
        chosen="${accessible[0]}"
    elif [ ${#accessible[@]} -eq 0 ]; then
        if $CREATE_REPO; then
            if [ ${#accounts[@]} -eq 1 ]; then
                chosen="${accounts[0]}"
            else
                echo -e "${YELLOW}No account has access to '$repo_input' (repo doesn't exist).${NC}"
                echo "Select an account to create the repository:"
                for i in "${!accounts[@]}"; do
                    printf "  %d. %s\n" $((i+1)) "${accounts[$i]}"
                done
                read -rp "Enter number: " choice
                choice="${choice//[[:space:]]/}"
                if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#accounts[@]} ]; then
                    chosen="${accounts[$((choice-1))]}"
                else
                    echo "Invalid choice" >&2
                    exit 1
                fi
            fi
        else
            echo -e "${RED}Error: Repository '$repo_input' not found or inaccessible.${NC}" >&2
            echo "Use -c to create it, or specify an account with -a." >&2
            exit 1
        fi
    else
        echo -e "${CYAN}Multiple accounts have access to this repository:${NC}"
        for i in "${!accessible[@]}"; do
            printf "  %d. %s\n" $((i+1)) "${accessible[$i]}"
        done
        read -rp "Choose an account number: " choice
        choice="${choice//[[:space:]]/}"
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#accessible[@]} ]; then
            chosen="${accessible[$((choice-1))]}"
        else
            echo "Invalid choice" >&2
            exit 1
        fi
    fi

    if ! load_account "$chosen"; then
        echo -e "${RED}Error: Failed to load credentials for account '$chosen'.${NC}" >&2
        exit 1
    fi

    # Normalize repo name
    if [[ "$repo_input" == */* ]]; then
        REPO="$repo_input"
    else
        REPO="$GITHUB_USERNAME/$repo_input"
    fi
}

run_upload() {
    # Prompt for repo if needed
    if [ -z "$REPO" ]; then
        read -rp "Repository name (e.g., user/repo or just repo): " REPO_INPUT
        REPO="$REPO_INPUT"
        [ -n "$REPO" ] || { echo -e "${RED}Error: Repository name required.${NC}" >&2; exit 1; }
    fi

    # Prompt for files if none provided
    if [ ${#FILES[@]} -eq 0 ]; then
        echo "Enter file paths (one per line, empty line to finish):"
        while IFS= read -r line; do
            [ -z "$line" ] && break
            FILES+=("$line")
            echo "  + $line"
        done
    fi

    [ ${#FILES[@]} -gt 0 ] || { echo -e "${RED}Error: No files specified.${NC}" >&2; exit 1; }

    resolve_account "$REPO"

    if ! check_repo_access "$REPO"; then
        if $CREATE_REPO; then
            create_repo
        else
            echo -e "${RED}Error: Repository '$REPO' not found or inaccessible.${NC}" >&2
            echo "Use -c to create it, or specify an account with -a." >&2
            exit 1
        fi
    fi

    upload_files "$REPO"
}

show_menu() {
    while true; do
        echo
        echo -e "${BOLD}=== GitHub Upload Tool ===${NC}"
        echo "1) Upload files"
        echo "2) Add another account"
        echo "3) List accounts"
        echo "4) Quit"
        read -rp "Choose [1-4]: " choice
        case "$choice" in
            1) run_upload ;;
            2) add_account ;;
            3) list_accounts ;;
            4) exit 0 ;;
            *) echo "Invalid option" ;;
        esac
    done
}

# -------------------------- Main --------------------------

# If -r flag provided, run upload directly; otherwise show menu
if [ -n "$REPO" ]; then
    run_upload
else
    # Check if any account exists; if none, add default first
    if [ ! -f "$DEFAULT_CONFIG" ] && [ ! -d "$ACCOUNTS_DIR" ]; then
        echo -e "${YELLOW}No accounts configured.${NC}"
        add_account "default"
    fi
    show_menu
fi