#!/usr/bin/env bash
################################################################################
# GitHub File Upload Tool (Production)
#
# Multi-account, interactive menu, encrypted backup, spinner progress.
# Requirements: git, curl, openssl
################################################################################

set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/github-upload"
DEFAULT_CONFIG="$CONFIG_DIR/config"
ACCOUNTS_DIR="$CONFIG_DIR/accounts"
BACKUP_DIR="$CONFIG_DIR/backups"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'
: "${COLOR_ERROR:=${RED}}"
: "${COLOR_SUCCESS:=${GREEN}}"
: "${COLOR_WARNING:=${YELLOW}}"
: "${COLOR_INFO:=${BLUE}}"
: "${COLOR_PROMPT:=${CYAN}}"
: "${COLOR_BOLD:=${BOLD}}"
: "${COLOR_RESET:=${NC}}"

# -------------------------- Spinner --------------------------

spinner() {
    local pid=$1
    local delay=0.1
    local spinstr='|/-\'
    while kill -0 "$pid" 2>/dev/null; do
        local temp=${spinstr#?}
        printf " [%c] " "$spinstr"
        spinstr=$temp${spinstr%"$temp"}
        sleep $delay
        printf "\b\b\b\b\b"
    done
    printf "    \b\b\b\b"
}

# -------------------------- Account Management --------------------------

add_account() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        read -rp "Account name (e.g., personal, work): " name
        [ -n "$name" ] || { echo "Account name required" >&2; exit 1; }
    fi
    local config_dir="$ACCOUNTS_DIR/$name"
    local config_file="$config_dir/config"
    if [ -e "$config_file" ]; then
        read -rp "Account '$name' exists. Overwrite? (y/N): " overwrite
        [[ "$overwrite" =~ ^[Yy]$ ]] || { echo "Aborted."; return; }
    fi
    echo -e "${COLOR_PROMPT}Adding account: $name${COLOR_RESET}"
    read -rp "GitHub username: " user
    read -rsp "GitHub Personal Access Token: " token
    echo
    mkdir -p "$config_dir"
    cat > "$config_file" <<EOF
GITHUB_USERNAME="$user"
GITHUB_TOKEN="$token"
EOF
    chmod 600 "$config_file"
    echo -e "${COLOR_SUCCESS}✓ Account '$name' saved.${COLOR_RESET}"
}

list_accounts() {
    echo "Configured accounts:"
    local count=0
    if [ -f "$DEFAULT_CONFIG" ]; then
        local user
        user=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" | cut -d= -f2- | tr -d '"' || echo "unknown")
        echo -e "  ${COLOR_INFO}default${COLOR_RESET}: $user"
        ((count++))
    fi
    if [ -d "$ACCOUNTS_DIR" ]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [ -f "$cfg" ] || continue
            local acc="$(basename "$(dirname "$cfg")")"
            local u
            u=$(grep '^GITHUB_USERNAME=' "$cfg" | cut -d= -f2- | tr -d '"' || echo "unknown")
            echo -e "  ${COLOR_INFO}$acc${COLOR_RESET}: $u"
            ((count++))
        done
    fi
    [ $count -eq 0 ] && echo "  (none configured)"
    echo
}

encrypt_file() {
    local input="$1" output="$2"
    read -rsp "Encryption password: " pass
    echo
    if openssl enc -aes-256-cbc -salt -pbkdf2 -in "$input" -out "$output" -pass "pass:$pass" 2>/dev/null; then
        chmod 600 "$output"
        echo -e "${COLOR_SUCCESS}✓ Encrypted to $output${COLOR_RESET}"
    else
        echo -e "${COLOR_ERROR}✗ Encryption failed${COLOR_RESET}" >&2
        return 1
    fi
}

decrypt_file() {
    local input="$1" output="$2"
    read -rsp "Decryption password: " pass
    echo
    if openssl enc -d -aes-256-cbc -pbkdf2 -in "$input" -out "$output" -pass "pass:$pass" 2>/dev/null; then
        echo -e "${COLOR_SUCCESS}✓ Decrypted to $output${COLOR_RESET}"
    else
        echo -e "${COLOR_ERROR}✗ Decryption failed${COLOR_RESET}" >&2
        return 1
    fi
}

export_accounts() {
    local backup_file="${1:-$BACKUP_DIR/accounts-$(date +%Y%m%d-%H%M%S).enc}"
    mkdir -p "$BACKUP_DIR"
    local temp_json="$BACKUP_DIR/temp-$$.json"

    echo "[" > "$temp_json"
    local first=1
    if [ -f "$DEFAULT_CONFIG" ]; then
        local user token
        user=$(grep '^GITHUB_USERNAME=' "$DEFAULT_CONFIG" | cut -d= -f2- | tr -d '"')
        token=$(grep '^GITHUB_TOKEN=' "$DEFAULT_CONFIG" | cut -d= -f2- | tr -d '"')
        if [ -n "$user" ] && [ -n "$token" ]; then
            user=${user//\"/\\\"}
            token=${token//\"/\\\"}
            [ "$first" -eq 0 ] && echo "," >> "$temp_json"
            printf '  {"name":"default","username":"%s","token":"%s"}\n' "$user" "$token" >> "$temp_json"
            first=0
        fi
    fi
    if [ -d "$ACCOUNTS_DIR" ]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [ -f "$cfg" ] || continue
            local acc="$(basename "$(dirname "$cfg")")"
            if source "$cfg" 2>/dev/null; then
                if [ -n "${GITHUB_USERNAME:-}" ] && [ -n "${GITHUB_TOKEN:-}" ]; then
                    local u="${GITHUB_USERNAME}" t="${GITHUB_TOKEN}"
                    u=${u//\"/\\\"}
                    t=${t//\"/\\\"}
                    [ "$first" -eq 0 ] && echo "," >> "$temp_json"
                    printf '  {"name":"%s","username":"%s","token":"%s"}\n' "$acc" "$u" "$t" >> "$temp_json"
                    first=0
                fi
            fi
        done
    fi
    echo -e "]" >> "$temp_json"

    if [ -s "$temp_json" ] && grep -q '^\[' "$temp_json"; then
        encrypt_file "$temp_json" "$backup_file"
        rm -f "$temp_json"
    else
        echo -e "${COLOR_ERROR}No accounts to export${COLOR_RESET}" >&2
        rm -f "$temp_json"
        return 1
    fi
}

import_accounts() {
    local backup_file="${1:-}"
    if [ -z "$backup_file" ]; then
        echo "Available backups:"
        ls -1t "$BACKUP_DIR"/*.enc 2>/dev/null | sed 's#.*/##' | nl || { echo "  (none)"; return 1; }
        read -rp "Enter backup filename (or full path): " backup_file
    fi
    if [ ! -f "$backup_file" ]; then
        echo -e "${COLOR_ERROR}Backup file not found: $backup_file${COLOR_RESET}" >&2
        return 1
    fi
    local temp_json="$BACKUP_DIR/import-$$.json"
    if decrypt_file "$backup_file" "$temp_json"; then
        # Read line by line, each line should be a JSON object or partial
        while IFS= read -r line; do
            # Skip empty lines and array brackets
            [[ "$line" =~ ^\s*\[|\]\s*$|^\s*$ ]] && continue
            # Extract fields
            local name username token
            name=$(echo "$line" | grep -o '"name":"[^"]*"' | head -1 | cut -d'"' -f4)
            username=$(echo "$line" | grep -o '"username":"[^"]*"' | head -1 | cut -d'"' -f4)
            token=$(echo "$line" | grep -o '"token":"[^"]*"' | head -1 | cut -d'"' -f4)
            if [ -n "$name" ] && [ -n "$username" ] && [ -n "$token" ]; then
                local cfg_dir="$ACCOUNTS_DIR/$name"
                mkdir -p "$cfg_dir"
                cat > "$cfg_dir/config" <<EOF
GITHUB_USERNAME="$username"
GITHUB_TOKEN="$token"
EOF
                chmod 600 "$cfg_dir/config"
                echo -e "${COLOR_SUCCESS}✓ Imported account: $name ($username)${COLOR_RESET}"
            fi
        done < "$temp_json"
        rm -f "$temp_json"
    fi
}

load_account() {
    local name="$1"
    unset GITHUB_USERNAME GITHUB_TOKEN 2>/dev/null

    if [ -z "$name" ] || [ "$name" = "default" ]; then
        [ -f "$DEFAULT_CONFIG" ] && source "$DEFAULT_CONFIG"
        [ -n "${GITHUB_USERNAME:-}" ] && [ -n "${GITHUB_TOKEN:-}" ] && return 0
        return 1
    else
        local cfg="$ACCOUNTS_DIR/$name/config"
        [ -f "$cfg" ] && source "$cfg"
        [ -n "${GITHUB_USERNAME:-}" ] && [ -n "${GITHUB_TOKEN:-}" ] && return 0
        local eu="GITHUB_USERNAME_${name^^}"
        local et="GITHUB_TOKEN_${name^^}"
        if [ -n "${!eu:-}" ] && [ -n "${!et:-}" ]; then
            GITHUB_USERNAME="${!eu}"
            GITHUB_TOKEN="${!et}"
            return 0
        fi
        return 1
    fi
}

check_repo_access() {
    local repo="$1"
    local token="${2:-$GITHUB_TOKEN}"
    local url="https://api.github.com/repos/$repo"
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" -H "Authorization: Bearer $token" "$url")
    [ "$code" = "200" ]
}

create_repo() {
    local repo_owner="${REPO%%/*}"
    local repo_name="${REPO##*/}"
    local is_private="false"
    [ "$VISIBILITY" = "--private" ] && is_private="true"

    local json
    if [ -n "$REPO_DESCRIPTION" ]; then
        local desc_esc
        desc_esc=$(printf '%s' "$REPO_DESCRIPTION" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')
        json="{\"name\":\"$repo_name\",\"description\":\"$desc_esc\",\"private\":$is_private}"
    else
        json="{\"name\":\"$repo_name\",\"private\":$is_private}"
    fi

    local api_url
    [ "$repo_owner" = "$GITHUB_USERNAME" ] && api_url="https://api.github.com/user/repos" || api_url="https://api.github.com/orgs/$repo_owner/repos"

    local response code
    response=$(curl -s -w "\n%{http_code}" -X POST \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        -d "$json" \
        "$api_url")
    code=$(printf "%s" "$response" | tail -n1)

    [ "$code" = "201" ] || [ "$code" = "200" ] || { echo -e "${COLOR_ERROR}Error: Failed to create repository (HTTP $code)${COLOR_RESET}" >&2; exit 1; }
    echo -e "${COLOR_SUCCESS}✓ Repository created${COLOR_RESET}"
}

upload_files() {
    local repo="$1"
    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" EXIT

    echo -e "${COLOR_INFO}Cloning repository...${COLOR_RESET}"
    if ! git clone "https://$GITHUB_USERNAME:$GITHUB_TOKEN@github.com/$repo.git" "$tmpdir" --single-branch 2>/dev/null; then
        echo -e "${COLOR_ERROR}Error: Failed to clone repository${COLOR_RESET}" >&2
        return 1
    fi
    echo -e "${COLOR_SUCCESS}Repository cloned${COLOR_RESET}"
    cd "$tmpdir"

    [ -n "$BRANCH" ] && git checkout "$BRANCH" 2>/dev/null || { echo -e "${COLOR_WARNING}Branch '$BRANCH' not found, creating it${COLOR_RESET}"; git checkout -b "$BRANCH" 2>/dev/null || true; }

    echo -e "${COLOR_INFO}Copying files...${COLOR_RESET}"
    local success=0
    for f in "${FILES[@]}"; do
        if [ -f "$f" ]; then
            cp "$f" ./
            echo "  + $(basename "$f")"
            ((success++))
        else
            echo -e "${COLOR_WARNING}Warning: '$f' not found, skipping${COLOR_RESET}" >&2
        fi
    done
    [ $success -gt 0 ] || { echo -e "${COLOR_ERROR}Error: No files to upload${COLOR_RESET}" >&2; return 1; }

    git add -A
    git diff --cached --quiet && { echo -e "${COLOR_WARNING}No changes to commit${COLOR_RESET}"; return 0; }

    echo -e "${COLOR_INFO}Committing...${COLOR_RESET}"
    git commit -m "$COMMIT_MSG" 2>/dev/null || { echo -e "${COLOR_ERROR}Commit failed${COLOR_RESET}" >&2; return 1; }

    echo -e "${COLOR_INFO}Pushing...${COLOR_RESET}"
    # Spinner while git push runs
    if git push origin HEAD 2>&1 | tee /dev/stderr | grep -q "error"; then
        echo -e "${COLOR_ERROR}✗ Push failed${COLOR_RESET}" >&2
        return 1
    else
        echo -e "${COLOR_SUCCESS}✓ Upload complete!${COLOR_RESET}"
        echo -e "View at: ${COLOR_BOLD}https://github.com/$repo${COLOR_RESET}"
        return 0
    fi
}

resolve_account() {
    local repo_input="$1"
    local accounts=()
    [ -f "$DEFAULT_CONFIG" ] && accounts+=("default")
    if [ -d "$ACCOUNTS_DIR" ]; then
        for cfg in "$ACCOUNTS_DIR"/*/config; do
            [ -f "$cfg" ] && accounts+=("$(basename "$(dirname "$cfg")")")
        done
    fi

    [ ${#accounts[@]} -eq 0 ] && { echo -e "${COLOR_WARNING}No accounts configured.${COLOR_RESET}"; add_account "default"; accounts=("default"); }

    if [ -n "$SPECIFIED_ACCOUNT" ]; then
        load_account "$SPECIFIED_ACCOUNT" || { echo -e "${COLOR_ERROR}Error: Account '$SPECIFIED_ACCOUNT' not found.${COLOR_RESET}" >&2; exit 1; }
        [[ "$repo_input" == */* ]] && REPO="$repo_input" || REPO="$GITHUB_USERNAME/$repo_input"
        return
    fi

    declare -a accessible=()
    for acc in "${accounts[@]}"; do
        load_account "$acc" 2>/dev/null || continue
        local candidate_repo="$repo_input"
        [[ "$candidate_repo" != */* ]] && candidate_repo="$GITHUB_USERNAME/$candidate_repo"
        check_repo_access "$candidate_repo" && accessible+=("$acc")
    done

    local chosen=""
    if [ ${#accessible[@]} -eq 1 ]; then
        chosen="${accessible[0]}"
    elif [ ${#accessible[@]} -eq 0 ]; then
        if $CREATE_REPO; then
            [ ${#accounts[@]} -eq 1 ] && chosen="${accounts[0]}" || {
                echo -e "${COLOR_WARNING}No account has access to '$repo_input' (repo doesn't exist).${COLOR_RESET}"
                echo "Select an account to create the repository:"
                for i in "${!accounts[@]}"; do printf "  %d. %s\n" $((i+1)) "${accounts[$i]}"; done
                read -rp "Enter number: " choice
                choice="${choice//[[:space:]]/}"
                [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#accounts[@]} ] && chosen="${accounts[$((choice-1))]}" || { echo "Invalid choice" >&2; exit 1; }
            }
        } || { echo -e "${COLOR_ERROR}Error: Repository '$repo_input' not found.${COLOR_RESET}" >&2; echo "Use -c to create it, or -a to specify account." >&2; exit 1; }
    else
        echo -e "${COLOR_INFO}Multiple accounts have access:${COLOR_RESET}"
        for i in "${!accessible[@]}"; do printf "  %d. %s\n" $((i+1)) "${accessible[$i]}"; done
        read -rp "Choose number: " choice
        choice="${choice//[[:space:]]/}"
        [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#accessible[@]} ] && chosen="${accessible[$((choice-1))]}" || { echo "Invalid choice" >&2; exit 1; }
    fi

    load_account "$chosen" || { echo -e "${COLOR_ERROR}Error: Failed to load account '$chosen'.${COLOR_RESET}" >&2; exit 1; }
    [[ "$repo_input" == */* ]] && REPO="$repo_input" || REPO="$GITHUB_USERNAME/$repo_input"
}

run_upload() {
    [ -z "$REPO" ] && { read -rp "Repository name: " REPO_INPUT; REPO="$REPO_INPUT"; } || true
    [ -n "$REPO" ] || { echo -e "${COLOR_ERROR}Repository name required${COLOR_RESET}" >&2; exit 1; }

    [ ${#FILES[@]} -gt 0 ] || {
        echo "Enter file paths (one per line, empty line to finish):"
        while IFS= read -r line; do
            [ -z "$line" ] && break
            FILES+=("$line")
        done
    }
    [ ${#FILES[@]} -gt 0 ] || { echo -e "${COLOR_ERROR}No files specified${COLOR_RESET}" >&2; exit 1; }

    resolve_account "$REPO"
    check_repo_access "$REPO" || { $CREATE_REPO && create_repo || { echo -e "${COLOR_ERROR}Repo not found${COLOR_RESET}" >&2; echo "Use -c to create." >&2; exit 1; }; }
    upload_files "$REPO"
}

show_menu() {
    while true; do
        echo
        echo -e "${COLOR_BOLD}=== GitHub Upload Tool ===${COLOR_RESET}"
        echo "1) Upload files"
        echo "2) Add another account"
        echo "3) List accounts"
        echo "4) Export accounts (backup)"
        echo "5) Import accounts (restore)"
        echo "6) Quit"
        read -rp "Choose [1-6]: " choice
        case "$choice" in
            1) run_upload ;;
            2) add_account ;;
            3) list_accounts ;;
            4) export_accounts ;;
            5) import_accounts ;;
            6) exit 0 ;;
            *) echo "Invalid option" ;;
        esac
    done
}

# -------------------------- Parse Arguments --------------------------

while [[ $# -gt 0 ]]; do
    case "$1" in
        -r|--repo) REPO="$2"; shift 2 ;;
        -m|--message) COMMIT_MSG="$2"; shift 2 ;;
        -b|--branch) BRANCH="$2"; shift 2 ;;
        -a|--account) SPECIFIED_ACCOUNT="$2"; shift 2 ;;
        -A|--add-account) ADD_ACCOUNT=true; ADD_ACCOUNT_NAME="${2:-}"; shift 2 ;;
        -c|--create) CREATE_REPO=true; shift ;;
        -d|--description) REPO_DESCRIPTION="$2"; shift 2 ;;
        --public) VISIBILITY="--public"; shift ;;
        --private) VISIBILITY="--private"; shift ;;
        --export) EXPORT=true; shift ;;
        --import) IMPORT=true; shift ;;
        --backup-file) BACKUP_FILE="$2"; shift 2 ;;
        -h|--help) HELP=true; shift ;;
        --list-accounts) LIST_ACCOUNTS=true; shift ;;
        -*) echo -e "${COLOR_ERROR}Error: Unknown option $1${COLOR_RESET}" >&2; exit 1 ;;
        *) FILES+=("$1"); shift ;;
    esac
done

$HELP && { head -70 "$0" | grep '^#' | sed -n '2,70p' | cut -c4-; exit 0; }

$ADD_ACCOUNT && { add_account "$ADD_ACCOUNT_NAME"; exit 0; }
$EXPORT && { export_accounts "$BACKUP_FILE"; exit 0; }
$IMPORT && { import_accounts "$BACKUP_FILE"; exit 0; }
${LIST_ACCOUNTS:-false} && { list_accounts; exit 0; }

for cmd in git curl openssl; do
    command -v "$cmd" >/dev/null || { echo -e "${COLOR_ERROR}Error: $cmd not installed${COLOR_RESET}" >&2; exit 1; }
done

# Direct mode if -r specified; otherwise menu
[ -n "$REPO" ] && run_upload || { [ ! -f "$DEFAULT_CONFIG" ] && [ ! -d "$ACCOUNTS_DIR" ] && add_account "default"; show_menu; }